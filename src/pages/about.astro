---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import aboutData from '../../content/pages/about.json';

const d = aboutData;

const approachIcons = [
  `<svg class="w-8 h-8 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" /></svg>`,
  `<svg class="w-8 h-8 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>`,
  `<svg class="w-8 h-8 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" /></svg>`,
];
---

<BaseLayout
  title={d.seo.title}
  description={d.seo.description}
>
  <!-- Hero -->
  <Hero
    badge={d.hero.badge}
    headline={d.hero.headline}
    subheadline={d.hero.subheadline}
  />

  <!-- Photo + Story -->
  <section class="section-padding">
    <div class="container-page">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">
        <div class="aspect-[3/4] rounded-2xl overflow-hidden">
          <img
            src={d.story.image}
            alt={d.story.imageAlt}
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>

        <!-- Story -->
        <div class="prose-brand">
          <h2 class="text-h2 font-serif text-brand-900 mb-6">{d.story.title}</h2>
          {d.story.paragraphs.map((paragraph, i) => (
            <p class:list={[
              i === 0 ? 'text-body-lg text-neutral-700' : 'text-body text-neutral-600',
              i < d.story.paragraphs.length - 1 ? 'mb-6' : '',
            ]}>
              {paragraph}
            </p>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Credentials & Education Timeline -->
  <section class="section-padding bg-brand-50/50">
    <div class="container-page">
      <SectionHeading
        title={d.credentials.title}
        subtitle={d.credentials.subtitle}
        tag={d.credentials.tag}
      />
      <div class="max-w-3xl mx-auto">
        <div class="relative">
          <!-- Timeline line -->
          <div class="absolute left-4 md:left-8 top-0 bottom-0 w-px bg-brand-200"></div>

          <div class="space-y-10">
            {d.credentials.timeline.map((item) => (
              <div class="relative pl-12 md:pl-20">
                <!-- Timeline dot -->
                <div class="absolute left-2.5 md:left-6.5 top-1.5 w-3 h-3 rounded-full bg-brand-500 ring-4 ring-brand-50"></div>
                <div class="card">
                  <span class="text-small font-semibold text-brand-600 uppercase tracking-wider">{item.years}</span>
                  <h3 class="text-h4 font-serif text-brand-900 mt-1">{item.title}</h3>
                  <p class="text-body font-medium text-neutral-500 mt-0.5">{item.institution}</p>
                  <p class="text-body text-neutral-600 mt-3">{item.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- My Approach -->
  <section class="section-padding">
    <div class="container-page">
      <SectionHeading
        title={d.approach.title}
        subtitle={d.approach.subtitle}
        tag={d.approach.tag}
      />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {d.approach.items.map((item, i) => (
          <div class="card text-center hover:border-brand-200 transition-colors">
            <div class="w-14 h-14 rounded-full bg-brand-50 flex items-center justify-center mx-auto mb-5">
              <Fragment set:html={approachIcons[i]} />
            </div>
            <h3 class="text-h3 font-serif text-brand-900 mb-3">{item.title}</h3>
            <p class="text-body text-neutral-600">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-50 section-padding">
    <div class="container-page">
      <div class="text-center max-w-2xl mx-auto mb-10">
        <h2 class="text-h2 font-serif text-brand-900 mb-4">{d.cta.title}</h2>
        <p class="text-body-lg text-neutral-600">
          {d.cta.description}
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-2xl mx-auto">
        <a href={d.cta.links[0].href} class="card text-center hover:border-brand-300 transition-colors group">
          <div class="w-12 h-12 rounded-full bg-brand-100 flex items-center justify-center mx-auto mb-4 group-hover:bg-brand-200 transition-colors">
            <svg class="w-6 h-6 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <h3 class="text-h4 font-serif text-brand-900 mb-2">{d.cta.links[0].title}</h3>
          <p class="text-small text-neutral-600">{d.cta.links[0].description}</p>
        </a>
        <a href={d.cta.links[1].href} class="card text-center hover:border-brand-300 transition-colors group">
          <div class="w-12 h-12 rounded-full bg-brand-100 flex items-center justify-center mx-auto mb-4 group-hover:bg-brand-200 transition-colors">
            <svg class="w-6 h-6 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" />
            </svg>
          </div>
          <h3 class="text-h4 font-serif text-brand-900 mb-2">{d.cta.links[1].title}</h3>
          <p class="text-small text-neutral-600">{d.cta.links[1].description}</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
