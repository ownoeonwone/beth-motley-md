---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import SpeakingForm from '../components/SpeakingForm.tsx';
---

<BaseLayout
  title="Speaking | Beth Motley, MD"
  description="Book Dr. Motley for your next event. Engaging, evidence-based presentations on lifestyle medicine, diabetes reversal, workplace wellness, and more."
>
  <!-- Hero -->
  <Hero
    badge="Speaking"
    headline="Bring Lifestyle Medicine to Your Audience"
    subheadline="Engaging, evidence-based presentations that translate science into practical, actionable takeaways."
  >
    <div class="mt-8">
      <a href="#booking-form" class="btn-primary">Book Dr. Motley to Speak</a>
    </div>
  </Hero>

  <!-- Speaking photo -->
  <section class="bg-white py-12 md:py-16">
    <div class="container-page max-w-5xl">
      <div class="rounded-2xl overflow-hidden shadow-lg">
        <img
          src="/images/speaking/aclm-2019-podium.png"
          alt="Dr. Motley presenting at the podium at the American College of Lifestyle Medicine 2019 conference"
          class="w-full h-auto"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- Speaking Topics -->
  <section class="section-padding bg-white">
    <div class="container-page">
      <SectionHeading
        title="Speaking Topics"
        subtitle="Each presentation is grounded in peer-reviewed evidence and tailored to your audience"
      />
      <div class="max-w-3xl mx-auto mb-8">
        <p class="text-body-lg text-neutral-600 text-center italic">My favorite topics...</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
        <div class="card">
          <h3 class="text-h4 font-serif text-brand-900 mb-2">Provider Tools for Implementing Lifestyle Medicine in Clinical Practice</h3>
        </div>
        <div class="card">
          <h3 class="text-h4 font-serif text-brand-900 mb-2">Lifestyle Medicine: Adding Years to Life and Life to Years</h3>
        </div>
        <div class="card">
          <h3 class="text-h4 font-serif text-brand-900 mb-2">Prescribing Plants: The Role of Plant-Based Nutrition in Cardiovascular Disease</h3>
        </div>
        <div class="card">
          <h3 class="text-h4 font-serif text-brand-900 mb-2">The Plant-Based Protocol for Reversing Type 2 Diabetes</h3>
        </div>
        <div class="card">
          <h3 class="text-h4 font-serif text-brand-900 mb-2">Preventing and Reversing Chronic Disease with Lifestyle Medicine: Translating the Evidence into Practical Application in the Clinic</h3>
        </div>
        <div class="card">
          <h3 class="text-h4 font-serif text-brand-900 mb-2">How to Raise an Adult: Promoting Healthful Eating for the Whole Family</h3>
        </div>
        <div class="card">
          <h3 class="text-h4 font-serif text-brand-900 mb-2">The Science of Sustainable Change: Rewiring Habits, Food, and Environment</h3>
        </div>
      </div>
    </div>
  </section>

  <!-- Audiences -->
  <section class="section-padding bg-brand-50/40">
    <div class="container-page">
      <SectionHeading
        title="Audiences"
        subtitle="Dr. Motley speaks to a wide range of groups and formats"
      />
      <div class="flex flex-wrap justify-center gap-3 max-w-3xl mx-auto">
        {[
          'Healthcare Conferences',
          'Corporate Wellness Events',
          'Medical Education (CME)',
          'Community Organizations',
          'Churches & Faith Groups',
          'Podcasts & Webinars',
          'Grand Rounds',
          'Employee Town Halls',
          'Health System Leadership',
          'Media & Press',
        ].map((audience) => (
          <span class="inline-flex items-center px-5 py-2.5 rounded-full bg-white border border-brand-200 text-body font-medium text-brand-800 shadow-sm">
            {audience}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section-padding bg-white">
    <div class="container-page">
      <SectionHeading
        title="What People Are Saying"
        subtitle="Feedback from medical professionals and community members"
      />
      <div class="mb-8">
        <h3 class="text-body font-semibold text-brand-600 uppercase tracking-wide text-center mb-6">From Medical Professionals</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
          <TestimonialCard
            quote="Fantastic! This is what I was interested in when I started wanting to get into medicine and I want to grow my practice with this basis."
            name="Conference Attendee"
            role="Medical Professional"
          />
          <TestimonialCard
            quote="Excellent choice for keynote speaker! Her excitement was infectious for the topic of lifestyle medicine. I appreciated the resources shared."
            name="Conference Attendee"
            role="Medical Professional"
          />
          <TestimonialCard
            quote="Engaging speaker. Loved getting the resources and recommendations. Seemed like a good presentation for the wide spectrum of familiarity with lifestyle medicine in the audience."
            name="Conference Attendee"
            role="Medical Professional"
          />
          <TestimonialCard
            quote="I cannot thank you enough for the 'Provider Tools for Implementing Lifestyle Medicine in Clinical Practice' talk you gave at ACLM last year. You gave me everything I needed to get started."
            name="ACLM Attendee"
            role="Medical Professional"
          />
        </div>
      </div>
      <div>
        <h3 class="text-body font-semibold text-brand-600 uppercase tracking-wide text-center mb-6">From Community Members</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
          <TestimonialCard
            quote="Approachable, practical, and excellent at simplifying complex topics into something anyone can understand."
            name="Community Member"
            role="Talk Attendee"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Media Reel Placeholder -->
  <section class="section-padding bg-brand-50/40">
    <div class="container-page max-w-4xl">
      <SectionHeading
        title="Speaking Reel"
        subtitle="See Dr. Motley in action"
      />
      <div class="aspect-video rounded-2xl overflow-hidden">
        <iframe
          src="https://www.youtube.com/embed/5O79xow0l8g"
          title="Beth Motley, MD: Heart Disease is a Foodborne Illness"
          class="w-full h-full"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <!-- Speaking Inquiry Form -->
  <section id="booking-form" class="section-padding bg-white">
    <div class="container-page max-w-2xl">
      <SectionHeading
        title="Book Dr. Motley for Your Event"
        subtitle="Tell us about your event and we will follow up within two business days to discuss availability, topics, and logistics."
      />
      <SpeakingForm client:visible />
    </div>
  </section>
</BaseLayout>
