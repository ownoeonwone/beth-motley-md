---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import SpeakingForm from '../components/SpeakingForm.tsx';
import speakingData from '../../content/pages/speaking.json';

const d = speakingData;
---

<BaseLayout
  title={d.seo.title}
  description={d.seo.description}
>
  <!-- Hero -->
  <Hero
    badge={d.hero.badge}
    headline={d.hero.headline}
    subheadline={d.hero.subheadline}
  >
    <div class="mt-8">
      <a href={d.hero.ctaHref} class="btn-primary">{d.hero.ctaText}</a>
    </div>
  </Hero>

  <!-- ACLM 2019 Keynote Highlight -->
  <section class="bg-white py-12 md:py-16">
    <div class="container-page max-w-5xl">
      <div class="rounded-2xl overflow-hidden shadow-lg mb-8">
        <img
          src={d.keynoteHighlight.image}
          alt={d.keynoteHighlight.imageAlt}
          class="w-full h-auto"
          loading="eager"
        />
      </div>
      <div class="text-center max-w-3xl mx-auto">
        <span class="badge mb-4 inline-block">{d.keynoteHighlight.tag}</span>
        <h2 class="text-h2 font-serif text-brand-900 mb-3">{d.keynoteHighlight.title}</h2>
        <p class="text-body-lg text-neutral-600 mb-2">{d.keynoteHighlight.location}</p>
        <p class="text-body-lg text-neutral-700 font-medium italic mb-2">
          "{d.keynoteHighlight.talkTitle}"
        </p>
        <p class="text-body text-neutral-500">
          {d.keynoteHighlight.description}
        </p>
      </div>
    </div>
  </section>

  <!-- Speaking Topics -->
  <section class="section-padding bg-white">
    <div class="container-page">
      <SectionHeading
        title={d.topics.title}
        subtitle={d.topics.subtitle}
      />
      <div class="max-w-3xl mx-auto mb-8">
        <p class="text-body-lg text-neutral-600 text-center italic">{d.topics.intro}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
        {d.topics.items.map((topic) => (
          <div class="card">
            <h3 class="text-h4 font-serif text-brand-900 mb-2">{topic}</h3>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Audiences -->
  <section class="section-padding bg-brand-50/40">
    <div class="container-page">
      <SectionHeading
        title={d.audiences.title}
        subtitle={d.audiences.subtitle}
      />
      <div class="flex flex-wrap justify-center gap-3 max-w-3xl mx-auto">
        {d.audiences.items.map((audience) => (
          <span class="inline-flex items-center px-5 py-2.5 rounded-full bg-white border border-brand-200 text-body font-medium text-brand-800 shadow-sm">
            {audience}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials from ACLM 2019 -->
  <section class="section-padding bg-white">
    <div class="container-page">
      <SectionHeading
        title={d.testimonials.title}
        subtitle={d.testimonials.subtitle}
      />

      <!-- Headline quotes -->
      <div class="max-w-3xl mx-auto mb-10">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
          {d.testimonials.headlineQuotes.map((hq) => (
            <div class="card bg-brand-50/60 border-brand-100">
              <p class="text-h3 font-serif text-brand-800 italic">"{hq.text}"</p>
              {hq.note && <p class="text-small text-neutral-500 mt-2">{hq.note}</p>}
            </div>
          ))}
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto mb-8">
        {d.testimonials.items.map((t) => (
          <TestimonialCard
            quote={t.quote}
            name={t.name}
            role={t.role}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Speaking Reel -->
  <section class="section-padding bg-brand-50/40">
    <div class="container-page max-w-5xl">
      <SectionHeading
        title={d.videos.title}
        subtitle={d.videos.subtitle}
      />
      <div class="space-y-10">
        <!-- Primary video -->
        <div>
          <div class="aspect-video rounded-2xl overflow-hidden shadow-lg">
            <iframe
              src={`https://www.youtube.com/embed/${d.videos.primary.embedId}`}
              title={d.videos.primary.title}
              class="w-full h-full"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
          <p class="text-body text-neutral-600 mt-3 text-center" set:html={`<strong>${d.videos.primary.caption.split(' — ')[0]}</strong>${d.videos.primary.caption.includes(' — ') ? ' — ' + d.videos.primary.caption.split(' — ').slice(1).join(' — ') : ''}`} />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {d.videos.secondary.map((video) => (
            <div>
              <div class="aspect-video rounded-2xl overflow-hidden shadow-lg">
                <iframe
                  src={`https://www.youtube.com/embed/${video.embedId}`}
                  title={video.title}
                  class="w-full h-full"
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                ></iframe>
              </div>
              <p class="text-body text-neutral-600 mt-3 text-center">
                <strong>{video.caption}</strong>
              </p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Speaking Inquiry Form -->
  <section id="booking-form" class="section-padding bg-white">
    <div class="container-page max-w-2xl">
      <SectionHeading
        title={d.bookingForm.title}
        subtitle={d.bookingForm.subtitle}
      />
      <SpeakingForm client:visible />
    </div>
  </section>
</BaseLayout>
