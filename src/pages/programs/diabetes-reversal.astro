---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import FAQ from '../../components/FAQ.astro';
import DiabetesForm from '../../components/DiabetesForm.tsx';
import EventsCalendar from '../../components/EventsCalendar';
import { getDiabetesReversalPage } from '../../lib/sanity';

const d = await getDiabetesReversalPage();
const calendarId = import.meta.env.PUBLIC_GOOGLE_CALENDAR_ID || '';
const apiKey = import.meta.env.PUBLIC_GOOGLE_API_KEY || '';

const whoIcons = [
  `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-3-3v6m-7 4h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
  </svg>`,
  `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
  </svg>`,
];

const whoColors = [
  'bg-brand-100 text-brand-700',
  'bg-lime-100 text-lime-700',
];
---

<BaseLayout
  title={d.seo.title}
  description={d.seo.description}
>
  <!-- Hero -->
  <Hero
    badge={d.hero.badge}
    headline={d.hero.headline}
    subheadline={d.hero.subheadline}
  />

  <!-- About This Program -->
  <section class="section-padding bg-white">
    <div class="container-page">
      <SectionHeading
        title={d.about.title}
        subtitle={d.about.subtitle}
      />
      <div class="max-w-3xl mx-auto prose-brand">
        <p class="text-body-lg text-neutral-700 leading-relaxed">
          {d.about.intro}
        </p>
        <p class="text-body text-neutral-600 mt-4 leading-relaxed">
          <Fragment set:html={d.about.body.replace(
            'The goal is not better numbers; it is getting diabetes off your diagnosis list.',
            '<strong class="text-brand-800">The goal is not better numbers; it is getting diabetes off your diagnosis list.</strong>'
          )} />
        </p>
        {d.about.groupVisitHeading && (
          <h3 class="text-h4 font-serif text-brand-900 mt-10 mb-4">{d.about.groupVisitHeading}</h3>
        )}
        {d.about.groupVisitParagraphs && d.about.groupVisitParagraphs.map((p, i) => (
          <p class:list={[
            'text-body text-neutral-600 leading-relaxed',
            i < d.about.groupVisitParagraphs.length - 1 ? 'mb-4' : '',
          ]}>
            {p}
          </p>
        ))}
      </div>
    </div>
  </section>

  <!-- Who Is This For? -->
  <section class="section-padding bg-brand-50/40">
    <div class="container-page">
      <SectionHeading
        title={d.whoIsThisFor.title}
        subtitle={d.whoIsThisFor.subtitle}
      />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        {d.whoIsThisFor.items.map((item, i) => (
          <div class="card text-center">
            <div class={`w-14 h-14 rounded-full ${whoColors[i]} flex items-center justify-center mx-auto mb-4`}>
              <Fragment set:html={whoIcons[i]} />
            </div>
            <h3 class="text-h4 font-serif text-brand-900 mb-2">{item.title}</h3>
            <p class="text-body text-neutral-600">
              {item.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Program Format -->
  <section class="section-padding bg-white">
    <div class="container-page">
      <SectionHeading
        title={d.format.title}
        subtitle={d.format.subtitle}
      />
      <div class="max-w-3xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
          {d.format.stats.map((stat) => (
            <div class="card text-center">
              <div class="text-h3 font-serif text-brand-700 mb-2">{stat.value}</div>
              <p class="text-body text-neutral-600">{stat.label}</p>
            </div>
          ))}
        </div>
        <div class="prose-brand">
          <p class="text-body text-neutral-600 leading-relaxed">
            {d.format.description}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Group Visits Work -->
  <section class="section-padding bg-brand-900">
    <div class="container-page">
      <div class="text-center mb-12">
        <span class="mb-4 inline-block inline-flex items-center px-3 py-1 rounded-full text-small font-medium border bg-brand-800 text-brand-200 border-brand-600">The Evidence</span>
        <h2 class="text-h2 font-serif text-white max-w-2xl mx-auto">Why Group Visits Work</h2>
        <p class="mt-3 text-body-lg text-brand-200 max-w-xl mx-auto">The research is clear. Here is what happens in the room.</p>
      </div>
      <div class="max-w-3xl mx-auto space-y-10">
        <div>
          <p class="text-body font-semibold text-lime-400 mb-2">You get more time with your physician.</p>
          <p class="text-body text-brand-200 leading-relaxed">
            Not just more time than a typical visit, but dramatically more. A traditional diabetes appointment gives you perhaps 7 minutes of real physician time. Each session here runs 75 minutes. Over the full program that is more direct physician time than most patients get from their diabetes provider in two years.
          </p>
        </div>
        <div>
          <p class="text-body font-semibold text-lime-400 mb-2">You learn more because of the people around you.</p>
          <p class="text-body text-brand-200 leading-relaxed">
            Research consistently shows this and it surprises people every time. In studies of group medical visits for diabetes, 92% of patients reported learning more about managing their condition than they ever had in traditional one-on-one care. Someone else in the room asks the question you were afraid to ask. Someone else's experience unlocks a realization you could not have reached alone. The group does not dilute the education; it multiplies it.
          </p>
        </div>
        <div>
          <p class="text-body font-semibold text-lime-400 mb-2">The accountability is built in, and it works.</p>
          <p class="text-body text-brand-200 leading-relaxed">
            Setting a goal with your doctor in a private appointment is one thing. Setting it in front of 10 other people who will ask you about it in two weeks is another. In published research on lifestyle medicine group programs, 97% of participants achieved or nearly achieved every health goal they set. That figure reflects what happens when accountability is structural rather than optional.
          </p>
        </div>
        <div>
          <p class="text-body font-semibold text-lime-400 mb-2">Something shifts when you are not alone in it.</p>
          <p class="text-body text-brand-200 leading-relaxed">
            Diabetes carries a weight that is hard to explain to someone who does not have it: the fatigue, the frustration, the feeling that you have already tried everything. One of the most consistent findings in the research on group medical visits is that patients report a profound sense of not being alone for the first time. That shift, from isolated patient to engaged member of a group, is not a soft benefit. It shows up in the lab values.
          </p>
        </div>
        <div>
          <p class="text-body font-semibold text-lime-400 mb-2">Most patients are skeptical before their first session.</p>
          <p class="text-body text-brand-200 leading-relaxed">
            That is completely normal and worth naming directly. Research shows that initial hesitation about the group format is nearly universal, and that it almost always dissolves after a single session. If you are uncertain, that uncertainty is part of the process. Come once. The program does the rest.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Schedule -->
  <section class="section-padding bg-white">
    <div class="container-page">
      <SectionHeading
        title={d.schedule.title}
        subtitle={d.schedule.subtitle}
      />
      <div class="max-w-3xl mx-auto space-y-6">
        <div class="card">
          <div class="space-y-3 text-body text-neutral-700">
            <p><strong class="text-brand-900">Dates:</strong> {d.schedule.dates}</p>
            <p><strong class="text-brand-900">Class times:</strong> {d.schedule.classTimes}</p>
          </div>
        </div>

        <!-- Live upcoming cohort dates from Google Calendar -->
        <div>
          <h3 class="font-serif text-h4 text-brand-900 mb-4">Upcoming Cohort Dates</h3>
          <EventsCalendar
            calendarId={calendarId}
            apiKey={apiKey}
            limit={3}
            showFeatured={false}
            showMonthHeaders={false}
            compact={true}
            client:visible
          />
          <div class="text-center mt-4">
            <a href="/events" class="inline-flex items-center text-small font-medium text-brand-600 hover:text-brand-800 transition-colors group">
              View all upcoming events
              <svg class="w-3.5 h-3.5 ml-1 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What to Expect / Session Curriculum -->
  <section class="section-padding bg-brand-50/40">
    <div class="container-page">
      <SectionHeading
        title={d.curriculum.title}
        subtitle={d.curriculum.subtitle}
      />
      <div class="max-w-3xl mx-auto space-y-6">
        {d.curriculum.sessions.map((phase, i) => (
          <div class="flex gap-5 items-start">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-brand-700 text-white flex items-center justify-center font-semibold text-small">
              {i + 1}
            </div>
            <div class="flex-1 pb-6 border-b border-neutral-100 last:border-0 last:pb-0">
              <span class="text-small font-medium text-brand-600 uppercase tracking-wide">{phase.session}</span>
              <h3 class="text-h4 font-serif text-brand-900 mt-1">{phase.title}</h3>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Eligibility -->
  <section class="section-padding bg-white">
    <div class="container-page">
      <SectionHeading
        title={d.eligibility.title}
        subtitle={d.eligibility.subtitle}
      />
      <div class="max-w-3xl mx-auto">
        <ul class="space-y-4">
          {d.eligibility.items.map((item) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-body text-neutral-700">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Billing -->
  <section class="section-padding bg-brand-50/40">
    <div class="container-page">
      <SectionHeading
        title={d.billing.title}
        subtitle={d.billing.subtitle}
      />
      <div class="max-w-3xl mx-auto prose-brand">
        <p class="text-body text-neutral-600 leading-relaxed">
          {d.billing.description}
        </p>
      </div>
    </div>
  </section>

  <!-- Results -->
  <section class="section-padding bg-brand-900">
    <div class="container-page">
      <div class="text-center mb-12">
        <h2 class="text-h2 font-serif text-white">{d.results.title}</h2>
        <p class="mt-3 text-body-lg text-brand-200 max-w-2xl mx-auto">
          {d.results.subtitle}
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {d.results.stats.map((stat) => (
          <div class="text-center p-6 rounded-xl bg-brand-800/50">
            <div class="text-display font-serif text-lime-400">{stat.value}</div>
            <p class="text-small font-semibold text-brand-100 mt-2">{stat.label}</p>
            {stat.description && (
              <p class="text-small text-brand-300 mt-3 leading-relaxed">{stat.description}</p>
            )}
          </div>
        ))}
      </div>
      <p class="text-center text-small text-brand-300 mt-8 max-w-2xl mx-auto">
        {d.results.disclaimer}
      </p>
    </div>
  </section>

  <!-- Featured Talk -->
  <section class="section-padding bg-brand-50/40">
    <div class="container-page max-w-4xl">
      <SectionHeading
        title={d.video.title}
        subtitle={d.video.subtitle}
      />
      <div class="aspect-video rounded-2xl overflow-hidden shadow-lg">
        <iframe
          src={`https://www.youtube.com/embed/${d.video.embedId}`}
          title="Dr. Motley on Lifestyle Medicine and Diabetes Reversal"
          class="w-full h-full"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section-padding bg-white">
    <div class="container-page max-w-3xl">
      <SectionHeading
        title={d.faq.title}
        subtitle={d.faq.subtitle}
      />
      <FAQ items={d.faq.items} />
    </div>
  </section>

  <!-- CTA / Application Form -->
  <section class="section-padding bg-brand-50/40">
    <div class="container-page max-w-2xl">
      <SectionHeading
        title={d.ctaForm.title}
        subtitle={d.ctaForm.subtitle}
      />
      <p class="text-body text-neutral-600 text-center mb-8 font-medium">
        {d.ctaForm.note}
      </p>
      <DiabetesForm client:visible />
    </div>
  </section>
</BaseLayout>
