---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import FAQ from '../../components/FAQ.astro';
import DiabetesForm from '../../components/DiabetesForm.tsx';

const faqItems = [
  {
    question: 'Is this covered by insurance?',
    answer: 'Yes. Our group visits are billed as medical visits, not wellness coaching, which means most commercial insurance plans, Medicare, and many Medicaid plans cover them. We verify your benefits before you begin so there are no surprises. You will be responsible for any applicable copays or coinsurance, just as you would for a standard office visit.',
  },
  {
    question: 'Do I need a referral from my doctor?',
    answer: 'A referral is not required to join the program, though some insurance plans may request one. You are welcome to self-refer. We also coordinate closely with your existing primary care provider so everyone stays on the same page regarding your care.',
  },
  {
    question: 'What if I am on insulin?',
    answer: 'Patients on insulin are welcome and often see significant results. Dr. Motley monitors your blood glucose closely throughout the program and adjusts medications as your numbers improve. Safety is our top priority, and medication changes are always made under direct physician supervision.',
  },
  {
    question: 'How is this different from a diet program?',
    answer: 'This is not a diet program. It is a physician-led medical program that uses evidence-based lifestyle interventions as the primary treatment for type 2 diabetes. You receive real medical care including lab work, medication management, and ongoing physician oversight. The lifestyle changes we teach are grounded in peer-reviewed research from the American College of Lifestyle Medicine.',
  },
  {
    question: 'Can I keep seeing my current doctor while doing this?',
    answer: 'Absolutely. We encourage it. Dr. Motley works alongside your existing healthcare team, not as a replacement. After each visit cycle, we send a summary to your primary care provider so they can see your progress and coordinate any ongoing care.',
  },
  {
    question: 'What happens after the six sessions?',
    answer: 'Graduation is just the beginning. After the initial program, you will have the option to join our maintenance shared medical appointments, which meet periodically to help you sustain your progress, troubleshoot challenges, and stay connected with your cohort.',
  },
];
---

<BaseLayout
  title="Diabetes Reversal Shared Medical Appointments | Beth Motley, MD"
  description="Evidence-based shared medical appointments that help patients reverse type 2 diabetes through lifestyle medicine. Insurance-accepted program in Greenville, SC led by Dr. Motley."
>
  <!-- Hero -->
  <Hero
    badge="Program"
    headline="Diabetes Reversal Shared Medical Appointments"
    subheadline="Evidence-based shared medical appointments designed to help you improve blood sugars, reduce medications, and work toward diabetes remission — led by a board-certified lifestyle medicine physician and covered by insurance."
  />

  <!-- About This Program -->
  <section class="section-padding bg-white">
    <div class="container-page">
      <SectionHeading
        title="About This Program"
        subtitle="A fundamentally different approach to diabetes care"
      />
      <div class="max-w-3xl mx-auto prose-brand">
        <p class="text-body-lg text-neutral-700 leading-relaxed">
          This program is fundamentally different from the traditional approach to "controlling" diabetes. Rather than simply managing blood sugars with medications or avoiding carbohydrates to work around insulin resistance, this model focuses on addressing the root cause: insulin resistance itself.
        </p>
        <p class="text-body text-neutral-600 mt-4 leading-relaxed">
          We do this through an evidence-based, plant-forward approach, aligned with the recommendations of the American College of Lifestyle Medicine. <strong class="text-brand-800">The goal is not better numbers; it is getting diabetes off your diagnosis list.</strong>
        </p>
      </div>
    </div>
  </section>

  <!-- Who Is This For? -->
  <section class="section-padding bg-brand-50/40">
    <div class="container-page">
      <SectionHeading
        title="Who Is This For?"
        subtitle="If any of the following describe you, this program may be a fit"
      />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        <div class="card text-center">
          <div class="w-14 h-14 rounded-full bg-brand-100 text-brand-700 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-3-3v6m-7 4h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-h4 font-serif text-brand-900 mb-2">Type 2 Diabetes</h3>
          <p class="text-body text-neutral-600">
            You have been diagnosed with type 2 diabetes and want to improve your blood sugars,
            reduce medications, and work toward remission.
          </p>
        </div>
        <div class="card text-center">
          <div class="w-14 h-14 rounded-full bg-lime-100 text-lime-700 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-h4 font-serif text-brand-900 mb-2">Prediabetes</h3>
          <p class="text-body text-neutral-600">
            Your labs show prediabetes or insulin resistance, and you want to reverse course
            before it progresses to a full diabetes diagnosis.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Program Format -->
  <section class="section-padding bg-white">
    <div class="container-page">
      <SectionHeading
        title="Program Format"
        subtitle="Hosted at Prisma Stone & Main Primary Care"
      />
      <div class="max-w-3xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
          <div class="card text-center">
            <div class="text-h3 font-serif text-brand-700 mb-2">8-12</div>
            <p class="text-body text-neutral-600">Participants per cohort</p>
          </div>
          <div class="card text-center">
            <div class="text-h3 font-serif text-brand-700 mb-2">75 min</div>
            <p class="text-body text-neutral-600">Per visit: medical care, education, and group discussion</p>
          </div>
          <div class="card text-center">
            <div class="text-h3 font-serif text-brand-700 mb-2">6</div>
            <p class="text-body text-neutral-600">Sessions, meeting every two weeks</p>
          </div>
        </div>
        <div class="prose-brand">
          <p class="text-body text-neutral-600 leading-relaxed">
            This small-group, physician-led program is designed to help individuals improve blood sugars, reduce medications, and work toward diabetes remission through evidence-based Lifestyle Medicine. Led by Dr. Beth Motley.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Schedule -->
  <section class="section-padding bg-brand-50/40">
    <div class="container-page">
      <SectionHeading
        title="Schedule"
        subtitle="Meets every two weeks for six sessions"
      />
      <div class="max-w-3xl mx-auto">
        <div class="card">
          <div class="space-y-3 text-body text-neutral-700">
            <p><strong class="text-brand-900">Dates:</strong> Next cohort dates pending</p>
            <p><strong class="text-brand-900">Class times:</strong> 8:30 &ndash; 9:45 AM or 10:15 &ndash; 11:30 AM</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What to Expect / Session Curriculum -->
  <section class="section-padding bg-white">
    <div class="container-page">
      <SectionHeading
        title="What to Expect"
        subtitle="Six sessions built on the pillars of lifestyle medicine"
      />
      <div class="max-w-3xl mx-auto space-y-6">
        {[
          {
            session: 'SMA 1',
            title: 'What Causes Diabetes? Reversing Insulin Resistance',
          },
          {
            session: 'SMA 2',
            title: 'Calorie Density, Satiety, and Alcohol',
          },
          {
            session: 'SMA 3',
            title: 'The Whole Grain Hierarchy and the Glycemic Index',
          },
          {
            session: 'SMA 4',
            title: 'Exercise and Sleep as Insulin Sensitivity Medicine',
          },
          {
            session: 'SMA 5',
            title: 'The Food Environment, Habits, and Long Term Adherence',
          },
          {
            session: 'SMA 6',
            title: 'Diabetes as a Vascular Disease: Protecting the Heart and Kidneys',
          },
        ].map((phase, i) => (
          <div class="flex gap-5 items-start">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-brand-700 text-white flex items-center justify-center font-semibold text-small">
              {i + 1}
            </div>
            <div class="flex-1 pb-6 border-b border-neutral-100 last:border-0 last:pb-0">
              <span class="text-small font-medium text-brand-600 uppercase tracking-wide">{phase.session}</span>
              <h3 class="text-h4 font-serif text-brand-900 mt-1">{phase.title}</h3>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Eligibility -->
  <section class="section-padding bg-brand-50/40">
    <div class="container-page">
      <SectionHeading
        title="Eligibility"
        subtitle="Requirements to participate"
      />
      <div class="max-w-3xl mx-auto">
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-brand-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span class="text-body text-neutral-700">Current diagnosis of type 2 diabetes or prediabetes</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-brand-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span class="text-body text-neutral-700">Established with any Prisma primary care provider and last visit within the past 12 months</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-brand-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span class="text-body text-neutral-700">Active MyChart account for eCheck-In prior to appointments</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-brand-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span class="text-body text-neutral-700">Willing to participate in a shared-visit format</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Billing -->
  <section class="section-padding bg-white">
    <div class="container-page">
      <SectionHeading
        title="Billing"
        subtitle="Billed as standard office visits through your insurance"
      />
      <div class="max-w-3xl mx-auto prose-brand">
        <p class="text-body text-neutral-600 leading-relaxed">
          These are billed as standard office visits through your insurance, just like when you go in for an A1c check and have medication adjusted.
        </p>
      </div>
    </div>
  </section>

  <!-- Results -->
  <section class="section-padding bg-brand-900">
    <div class="container-page">
      <div class="text-center mb-12">
        <h2 class="text-h2 font-serif text-white">Real Results, Real Patients</h2>
        <p class="mt-3 text-body-lg text-brand-200 max-w-xl mx-auto">
          Outcomes from lifestyle medicine group visit programs across the country consistently show meaningful improvements.
        </p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto">
        <div class="text-center p-6 rounded-xl bg-brand-800/50">
          <div class="text-display font-serif text-lime-400">1.5%</div>
          <p class="text-small text-brand-200 mt-2">Average A1c Reduction</p>
        </div>
        <div class="text-center p-6 rounded-xl bg-brand-800/50">
          <div class="text-display font-serif text-lime-400">62%</div>
          <p class="text-small text-brand-200 mt-2">Patients Reducing Medications</p>
        </div>
        <div class="text-center p-6 rounded-xl bg-brand-800/50">
          <div class="text-display font-serif text-lime-400">15 lbs</div>
          <p class="text-small text-brand-200 mt-2">Average Weight Loss</p>
        </div>
        <div class="text-center p-6 rounded-xl bg-brand-800/50">
          <div class="text-display font-serif text-lime-400">97%</div>
          <p class="text-small text-brand-200 mt-2">Patient Satisfaction</p>
        </div>
      </div>
      <p class="text-center text-small text-brand-300 mt-8 max-w-lg mx-auto">
        Statistics reflect published outcomes from lifestyle medicine group visit programs nationally.
        Individual results vary based on adherence, baseline health, and other factors.
      </p>
    </div>
  </section>

  <!-- Featured Talk -->
  <section class="section-padding bg-brand-50/40">
    <div class="container-page max-w-4xl">
      <SectionHeading
        title="Dr. Motley on Diabetes Reversal"
        subtitle="Watch Dr. Motley explain the science behind reversing type 2 diabetes with lifestyle medicine"
      />
      <div class="aspect-video rounded-2xl overflow-hidden shadow-lg">
        <iframe
          src="https://www.youtube.com/embed/cNI41n_fdSI"
          title="Dr. Motley on Lifestyle Medicine and Diabetes Reversal"
          class="w-full h-full"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section-padding bg-white">
    <div class="container-page max-w-3xl">
      <SectionHeading
        title="Frequently Asked Questions"
        subtitle="Common questions about the Diabetes Reversal Shared Medical Appointments"
      />
      <FAQ items={faqItems} />
    </div>
  </section>

  <!-- CTA / Application Form -->
  <section class="section-padding bg-brand-50/40">
    <div class="container-page max-w-2xl">
      <SectionHeading
        title="Ready to Get Started?"
        subtitle="Space is limited. Please contact the office directly to enroll or request a referral from your PCP."
      />
      <p class="text-body text-neutral-600 text-center mb-8 font-medium">
        Please do NOT enroll if you are not serious about participation.
      </p>
      <DiabetesForm client:visible />
    </div>
  </section>
</BaseLayout>
