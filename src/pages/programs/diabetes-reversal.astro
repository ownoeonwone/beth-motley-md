---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import FAQ from '../../components/FAQ.astro';
import DiabetesForm from '../../components/DiabetesForm.tsx';
import drData from '../../../content/pages/diabetes-reversal.json';

const d = drData;

const whoIcons = [
  `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-3-3v6m-7 4h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
  </svg>`,
  `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
  </svg>`,
];

const whoColors = [
  'bg-brand-100 text-brand-700',
  'bg-lime-100 text-lime-700',
];
---

<BaseLayout
  title={d.seo.title}
  description={d.seo.description}
>
  <!-- Hero -->
  <Hero
    badge={d.hero.badge}
    headline={d.hero.headline}
    subheadline={d.hero.subheadline}
  />

  <!-- About This Program -->
  <section class="section-padding bg-white">
    <div class="container-page">
      <SectionHeading
        title={d.about.title}
        subtitle={d.about.subtitle}
      />
      <div class="max-w-3xl mx-auto prose-brand">
        <p class="text-body-lg text-neutral-700 leading-relaxed">
          {d.about.intro}
        </p>
        <p class="text-body text-neutral-600 mt-4 leading-relaxed">
          <Fragment set:html={d.about.body.replace(
            'The goal is not better numbers; it is getting diabetes off your diagnosis list.',
            '<strong class="text-brand-800">The goal is not better numbers; it is getting diabetes off your diagnosis list.</strong>'
          )} />
        </p>
      </div>
    </div>
  </section>

  <!-- Who Is This For? -->
  <section class="section-padding bg-brand-50/40">
    <div class="container-page">
      <SectionHeading
        title={d.whoIsThisFor.title}
        subtitle={d.whoIsThisFor.subtitle}
      />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        {d.whoIsThisFor.items.map((item, i) => (
          <div class="card text-center">
            <div class={`w-14 h-14 rounded-full ${whoColors[i]} flex items-center justify-center mx-auto mb-4`}>
              <Fragment set:html={whoIcons[i]} />
            </div>
            <h3 class="text-h4 font-serif text-brand-900 mb-2">{item.title}</h3>
            <p class="text-body text-neutral-600">
              {item.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Program Format -->
  <section class="section-padding bg-white">
    <div class="container-page">
      <SectionHeading
        title={d.format.title}
        subtitle={d.format.subtitle}
      />
      <div class="max-w-3xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
          {d.format.stats.map((stat) => (
            <div class="card text-center">
              <div class="text-h3 font-serif text-brand-700 mb-2">{stat.value}</div>
              <p class="text-body text-neutral-600">{stat.label}</p>
            </div>
          ))}
        </div>
        <div class="prose-brand">
          <p class="text-body text-neutral-600 leading-relaxed">
            {d.format.description}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Schedule -->
  <section class="section-padding bg-brand-50/40">
    <div class="container-page">
      <SectionHeading
        title={d.schedule.title}
        subtitle={d.schedule.subtitle}
      />
      <div class="max-w-3xl mx-auto">
        <div class="card">
          <div class="space-y-3 text-body text-neutral-700">
            <p><strong class="text-brand-900">Dates:</strong> {d.schedule.dates}</p>
            <p><strong class="text-brand-900">Class times:</strong> {d.schedule.classTimes}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What to Expect / Session Curriculum -->
  <section class="section-padding bg-white">
    <div class="container-page">
      <SectionHeading
        title={d.curriculum.title}
        subtitle={d.curriculum.subtitle}
      />
      <div class="max-w-3xl mx-auto space-y-6">
        {d.curriculum.sessions.map((phase, i) => (
          <div class="flex gap-5 items-start">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-brand-700 text-white flex items-center justify-center font-semibold text-small">
              {i + 1}
            </div>
            <div class="flex-1 pb-6 border-b border-neutral-100 last:border-0 last:pb-0">
              <span class="text-small font-medium text-brand-600 uppercase tracking-wide">{phase.session}</span>
              <h3 class="text-h4 font-serif text-brand-900 mt-1">{phase.title}</h3>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Eligibility -->
  <section class="section-padding bg-brand-50/40">
    <div class="container-page">
      <SectionHeading
        title={d.eligibility.title}
        subtitle={d.eligibility.subtitle}
      />
      <div class="max-w-3xl mx-auto">
        <ul class="space-y-4">
          {d.eligibility.items.map((item) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-body text-neutral-700">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Billing -->
  <section class="section-padding bg-white">
    <div class="container-page">
      <SectionHeading
        title={d.billing.title}
        subtitle={d.billing.subtitle}
      />
      <div class="max-w-3xl mx-auto prose-brand">
        <p class="text-body text-neutral-600 leading-relaxed">
          {d.billing.description}
        </p>
      </div>
    </div>
  </section>

  <!-- Results -->
  <section class="section-padding bg-brand-900">
    <div class="container-page">
      <div class="text-center mb-12">
        <h2 class="text-h2 font-serif text-white">{d.results.title}</h2>
        <p class="mt-3 text-body-lg text-brand-200 max-w-xl mx-auto">
          {d.results.subtitle}
        </p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto">
        {d.results.stats.map((stat) => (
          <div class="text-center p-6 rounded-xl bg-brand-800/50">
            <div class="text-display font-serif text-lime-400">{stat.value}</div>
            <p class="text-small text-brand-200 mt-2">{stat.label}</p>
          </div>
        ))}
      </div>
      <p class="text-center text-small text-brand-300 mt-8 max-w-lg mx-auto">
        {d.results.disclaimer}
      </p>
    </div>
  </section>

  <!-- Featured Talk -->
  <section class="section-padding bg-brand-50/40">
    <div class="container-page max-w-4xl">
      <SectionHeading
        title={d.video.title}
        subtitle={d.video.subtitle}
      />
      <div class="aspect-video rounded-2xl overflow-hidden shadow-lg">
        <iframe
          src={`https://www.youtube.com/embed/${d.video.embedId}`}
          title="Dr. Motley on Lifestyle Medicine and Diabetes Reversal"
          class="w-full h-full"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section-padding bg-white">
    <div class="container-page max-w-3xl">
      <SectionHeading
        title={d.faq.title}
        subtitle={d.faq.subtitle}
      />
      <FAQ items={d.faq.items} />
    </div>
  </section>

  <!-- CTA / Application Form -->
  <section class="section-padding bg-brand-50/40">
    <div class="container-page max-w-2xl">
      <SectionHeading
        title={d.ctaForm.title}
        subtitle={d.ctaForm.subtitle}
      />
      <p class="text-body text-neutral-600 text-center mb-8 font-medium">
        {d.ctaForm.note}
      </p>
      <DiabetesForm client:visible />
    </div>
  </section>
</BaseLayout>
