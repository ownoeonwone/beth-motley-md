---
import BaseLayout from '../layouts/BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';

const seo = {
  title: 'Terms of Use | Beth Motley, MD',
  description: 'Terms of use for bethmotleymd.com, including medical disclaimer, intellectual property, and governing law.',
};

const tocItems = [
  { id: 'acceptance', label: 'Acceptance of Terms' },
  { id: 'no-medical-advice', label: 'No Medical Advice' },
  { id: 'use-of-site', label: 'Use of This Site' },
  { id: 'intellectual-property', label: 'Intellectual Property' },
  { id: 'user-submissions', label: 'User Submissions' },
  { id: 'third-party-links', label: 'Third-Party Links' },
  { id: 'disclaimer-of-warranties', label: 'Disclaimer of Warranties' },
  { id: 'limitation-of-liability', label: 'Limitation of Liability' },
  { id: 'indemnification', label: 'Indemnification' },
  { id: 'governing-law', label: 'Governing Law' },
  { id: 'changes', label: 'Changes to These Terms' },
  { id: 'contact', label: 'Contact Us' },
];
---

<BaseLayout
  title={seo.title}
  description={seo.description}
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-brand-50 to-white py-14 md:py-20">
    <div class="max-w-[680px] mx-auto px-5 md:px-8">
      <span class="badge mb-4 inline-block">Legal</span>
      <h1 class="text-h1 md:text-display font-serif text-brand-900">Terms of Use</h1>
      <p class="mt-3 text-body text-neutral-500">Effective Date: March 21, 2026</p>
    </div>
  </section>

  <!-- Content -->
  <section class="section-padding bg-white">
    <div class="max-w-[680px] mx-auto px-5 md:px-8">
      <TableOfContents items={tocItems} />

      <div class="prose-brand space-y-12">

        <!-- Section 1 -->
        <div>
          <h2 id="acceptance" class="text-h2 font-serif text-brand-900 mb-4 pt-4 border-t border-neutral-100">1. Acceptance of Terms</h2>
          <p>By accessing and using bethmotleymd.com (the "Site"), you agree to be bound by these Terms of Use ("Terms"). If you do not agree to these Terms, please do not use the Site. These Terms constitute a legally binding agreement between you and Beth Motley, MD ("we," "us," or "our").</p>
        </div>

        <!-- Section 2 — No Medical Advice (highlighted) -->
        <div>
          <h2 id="no-medical-advice" class="text-h2 font-serif text-brand-900 mb-4 pt-4 border-t border-neutral-100">2. No Medical Advice</h2>
          <div class="border-l-4 border-brand-500 bg-brand-50 rounded-r-brand p-6">
            <p class="text-body text-brand-900 font-medium leading-relaxed mb-4">
              The content on this Site is provided for general informational and educational purposes only. It is not intended to be, and should not be construed as, medical advice, diagnosis, or treatment.
            </p>
            <p class="text-body text-brand-800 leading-relaxed mb-4">
              Nothing on this Site creates a physician-patient relationship between you and Beth Motley, MD. A physician-patient relationship is established only through a formal, in-person or telehealth clinical encounter with appropriate intake, consent, and documentation.
            </p>
            <p class="text-body text-brand-800 leading-relaxed mb-4">
              Always seek the advice of your physician or other qualified healthcare provider with any questions you may have regarding a medical condition. Never disregard professional medical advice or delay in seeking it because of something you have read on this Site.
            </p>
            <p class="text-body text-brand-800 leading-relaxed">
              <strong>If you think you may have a medical emergency, call 911 or go to your nearest emergency room immediately.</strong>
            </p>
          </div>
        </div>

        <!-- Section 3 -->
        <div>
          <h2 id="use-of-site" class="text-h2 font-serif text-brand-900 mb-4 pt-4 border-t border-neutral-100">3. Use of This Site</h2>
          <p>You agree to use this Site only for lawful purposes and in a manner that does not infringe on the rights of, or restrict or inhibit the use of, this Site by any third party. You agree not to:</p>
          <ul>
            <li>Use the Site in any way that violates applicable local, state, national, or international law</li>
            <li>Attempt to gain unauthorized access to any portion of the Site or its systems</li>
            <li>Use automated tools, bots, or scrapers to access the Site without permission</li>
            <li>Submit false, misleading, or fraudulent information through any form on the Site</li>
          </ul>
        </div>

        <!-- Section 4 -->
        <div>
          <h2 id="intellectual-property" class="text-h2 font-serif text-brand-900 mb-4 pt-4 border-t border-neutral-100">4. Intellectual Property</h2>
          <p>All content on this Site, including text, images, graphics, logos, audio, video, and software, is the property of Beth Motley, MD or its content suppliers and is protected by United States and international copyright, trademark, and other intellectual property laws.</p>
          <p class="mt-4">You may not reproduce, distribute, modify, create derivative works of, publicly display, or otherwise use any content from this Site without prior written permission, except for personal, non-commercial use such as printing a single copy for your own reference.</p>
        </div>

        <!-- Section 5 -->
        <div>
          <h2 id="user-submissions" class="text-h2 font-serif text-brand-900 mb-4 pt-4 border-t border-neutral-100">5. User Submissions</h2>
          <p>When you submit information through forms on this Site (such as enrollment forms, consultation requests, or contact forms), you represent that the information you provide is accurate and truthful.</p>
          <p class="mt-4">Health information submitted through this Site is handled in accordance with our <a href="/privacy-policy">Privacy Policy</a> and <a href="/notice-of-privacy-practices">Notice of Privacy Practices</a>.</p>
        </div>

        <!-- Section 6 -->
        <div>
          <h2 id="third-party-links" class="text-h2 font-serif text-brand-900 mb-4 pt-4 border-t border-neutral-100">6. Third-Party Links</h2>
          <p>This Site may contain links to third-party websites or services that are not owned or controlled by Beth Motley, MD. We are not responsible for the content, privacy policies, or practices of any third-party websites. We encourage you to review the terms and privacy policies of any third-party site you visit.</p>
        </div>

        <!-- Section 7 -->
        <div>
          <h2 id="disclaimer-of-warranties" class="text-h2 font-serif text-brand-900 mb-4 pt-4 border-t border-neutral-100">7. Disclaimer of Warranties</h2>
          <p>This Site is provided on an "as is" and "as available" basis without warranties of any kind, either express or implied. To the fullest extent permitted by law, Beth Motley, MD disclaims all warranties, including implied warranties of merchantability, fitness for a particular purpose, and non-infringement.</p>
          <p class="mt-4">We do not warrant that the Site will be uninterrupted, error-free, or free of viruses or other harmful components.</p>
        </div>

        <!-- Section 8 -->
        <div>
          <h2 id="limitation-of-liability" class="text-h2 font-serif text-brand-900 mb-4 pt-4 border-t border-neutral-100">8. Limitation of Liability</h2>
          <p>To the fullest extent permitted by law, Beth Motley, MD shall not be liable for any indirect, incidental, special, consequential, or punitive damages arising out of or relating to your use of, or inability to use, this Site, even if we have been advised of the possibility of such damages.</p>
        </div>

        <!-- Section 9 -->
        <div>
          <h2 id="indemnification" class="text-h2 font-serif text-brand-900 mb-4 pt-4 border-t border-neutral-100">9. Indemnification</h2>
          <p>You agree to indemnify, defend, and hold harmless Beth Motley, MD, her employees, agents, and affiliates from and against any and all claims, damages, losses, liabilities, costs, and expenses (including reasonable attorneys' fees) arising out of or relating to your use of the Site or your violation of these Terms.</p>
        </div>

        <!-- Section 10 -->
        <div>
          <h2 id="governing-law" class="text-h2 font-serif text-brand-900 mb-4 pt-4 border-t border-neutral-100">10. Governing Law</h2>
          <p>These Terms are governed by and construed in accordance with the laws of the State of South Carolina, without regard to its conflict of law principles. Any dispute arising out of or relating to these Terms or your use of the Site shall be resolved exclusively in the state or federal courts located in Greenville County, South Carolina.</p>
        </div>

        <!-- Section 11 -->
        <div>
          <h2 id="changes" class="text-h2 font-serif text-brand-900 mb-4 pt-4 border-t border-neutral-100">11. Changes to These Terms</h2>
          <p>We reserve the right to modify these Terms at any time. Changes will be effective immediately upon posting to this page. The "Effective Date" at the top of this page will be updated accordingly. Your continued use of the Site after any changes constitutes your acceptance of the revised Terms.</p>
        </div>

        <!-- Section 12 -->
        <div>
          <h2 id="contact" class="text-h2 font-serif text-brand-900 mb-4 pt-4 border-t border-neutral-100">12. Contact Us</h2>
          <p>If you have questions about these Terms of Use, please contact us:</p>
          <p class="mt-4">
            <strong>Beth Motley, MD</strong><br />
            Email: <a href="mailto:info@bethmotleymd.com">info@bethmotleymd.com</a><br />
            Phone: <a href="tel:+18642717761">(864) 271-7761</a>
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
