---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ContactForm from '../components/ContactForm';
import { getContactPage } from '../lib/sanity';

const d = await getContactPage();

const quickLinkIcons = [
  `<svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" /></svg>`,
  `<svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>`,
  `<svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>`,
];

const socialIcons: Record<string, string> = {
  Facebook: `<svg class="w-4 h-4 text-brand-600" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" /></svg>`,
  Instagram: `<svg class="w-4 h-4 text-brand-600" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" /></svg>`,
};
---

<BaseLayout
  title={d.seo.title}
  description={d.seo.description}
>
  <!-- Hero -->
  <Hero
    badge={d.hero.badge}
    headline={d.hero.headline}
    subheadline={d.hero.subheadline}
    size="medium"
  />

  <!-- Two-column layout -->
  <section class="section-padding">
    <div class="container-page">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">

        <!-- Left: Contact Form -->
        <div class="lg:col-span-3">
          <h2 class="text-h3 font-serif text-brand-900 mb-2">{d.form.title}</h2>
          <p class="text-body text-neutral-500 mb-8">
            {d.form.subtitle}
          </p>
          <ContactForm client:load />
        </div>

        <!-- Right: Contact Info -->
        <div class="lg:col-span-2 space-y-8">

          <!-- Location card -->
          <div class="card">
            <h3 class="text-h4 font-serif text-brand-900 mb-4">{d.location.title}</h3>
            <div class="flex items-start gap-3 text-body text-neutral-600">
              <svg class="w-5 h-5 text-brand-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
              <div>
                <p class="font-medium text-brand-900">{d.location.name}</p>
                <p class="text-small text-neutral-500 mt-1">{d.location.detail}</p>
              </div>
            </div>
          </div>

          <!-- Response time -->
          <div class="card">
            <h3 class="text-h4 font-serif text-brand-900 mb-4">{d.responseTime.title}</h3>
            <div class="flex items-start gap-3 text-body text-neutral-600">
              <svg class="w-5 h-5 text-brand-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-medium text-brand-900">{d.responseTime.time}</p>
                <p class="text-small text-neutral-500 mt-1">{d.responseTime.detail}</p>
              </div>
            </div>
          </div>

          <!-- Social links -->
          <div class="card">
            <h3 class="text-h4 font-serif text-brand-900 mb-4">{d.social.title}</h3>
            <div class="space-y-3">
              {d.social.links.map((link) => (
                <a href={link.href} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-body text-neutral-600 hover:text-brand-700 transition-colors group">
                  <div class="w-9 h-9 rounded-full bg-brand-50 flex items-center justify-center group-hover:bg-brand-100 transition-colors">
                    <Fragment set:html={socialIcons[link.platform]} />
                  </div>
                  <span>{link.platform}</span>
                </a>
              ))}
            </div>
          </div>

          <!-- Quick links -->
          <div class="card">
            <h3 class="text-h4 font-serif text-brand-900 mb-4">{d.quickLinks.title}</h3>
            <div class="space-y-4">
              {d.quickLinks.items.map((link, i) => (
                <a href={link.href} class="flex items-start gap-3 group">
                  <div class="w-9 h-9 rounded-full bg-brand-50 flex items-center justify-center flex-shrink-0 group-hover:bg-brand-100 transition-colors mt-0.5">
                    <Fragment set:html={quickLinkIcons[i]} />
                  </div>
                  <div>
                    <p class="text-body font-medium text-brand-900 group-hover:text-brand-700 transition-colors">{link.title}</p>
                    <p class="text-small text-neutral-500">{link.description}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>
</BaseLayout>
