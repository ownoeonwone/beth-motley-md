---
import BaseLayout from '../layouts/BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';

const seo = {
  title: 'Privacy Policy | Beth Motley, MD',
  description: 'How bethmotleymd.com collects, uses, and protects information submitted through this website.',
};

const tocItems = [
  { id: 'information-we-collect', label: 'Information We Collect' },
  { id: 'how-we-use', label: 'How We Use Your Information' },
  { id: 'how-we-share', label: 'How We Share Your Information' },
  { id: 'cookies', label: 'Cookies and Tracking Technologies' },
  { id: 'data-security', label: 'Data Security' },
  { id: 'data-retention', label: 'Data Retention' },
  { id: 'your-rights', label: 'Your Rights and Choices' },
  { id: 'childrens-privacy', label: "Children's Privacy" },
  { id: 'third-party-links', label: 'Third-Party Links' },
  { id: 'changes', label: 'Changes to This Privacy Policy' },
  { id: 'contact', label: 'Contact Us' },
];
---

<BaseLayout
  title={seo.title}
  description={seo.description}
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-brand-50 to-white py-14 md:py-20">
    <div class="max-w-[680px] mx-auto px-5 md:px-8">
      <span class="badge mb-4 inline-block">Legal</span>
      <h1 class="text-h1 md:text-display font-serif text-brand-900">Privacy Policy</h1>
      <p class="mt-3 text-body text-neutral-500">Effective Date: March 21, 2026</p>
    </div>
  </section>

  <!-- Content -->
  <section class="section-padding bg-white">
    <div class="max-w-[680px] mx-auto px-5 md:px-8">
      <TableOfContents items={tocItems} />

      <div class="prose-brand space-y-12">
        <p>
          Beth Motley, MD ("we," "us," or "our") operates the website bethmotleymd.com (the "Site"). This Privacy Policy explains how we collect, use, disclose, and protect information when you visit our Site or submit information through our forms.
        </p>
        <p>
          By using this Site, you agree to the collection and use of information in accordance with this policy. If you do not agree with this policy, please do not use the Site.
        </p>

        <!-- Section 1 -->
        <div>
          <h2 id="information-we-collect" class="text-h2 font-serif text-brand-900 mb-4 pt-4 border-t border-neutral-100">1. Information We Collect</h2>

          <h3 class="text-h4 font-serif text-brand-900 mt-6 mb-2">a. Information You Provide Directly</h3>
          <p>When you fill out a form on our Site (such as an enrollment form, consultation request, or contact form), we may collect:</p>
          <ul>
            <li>Full name</li>
            <li>Email address</li>
            <li>Phone number</li>
            <li>Date of birth</li>
            <li>Insurance information</li>
            <li>Health-related information you choose to share (such as current diagnoses, medications, or health goals)</li>
            <li>Any other information you voluntarily provide in open text fields</li>
          </ul>

          <h3 class="text-h4 font-serif text-brand-900 mt-6 mb-2">b. Information Collected Automatically</h3>
          <p>When you visit the Site, we may automatically collect certain technical information, including:</p>
          <ul>
            <li>IP address</li>
            <li>Browser type and version</li>
            <li>Device type</li>
            <li>Pages visited, time spent on pages, and referring URLs</li>
            <li>Cookies and similar tracking technologies (see Section 4)</li>
          </ul>
        </div>

        <!-- Section 2 -->
        <div>
          <h2 id="how-we-use" class="text-h2 font-serif text-brand-900 mb-4 pt-4 border-t border-neutral-100">2. How We Use Your Information</h2>
          <p>We use the information we collect for the following purposes:</p>
          <ul>
            <li>To respond to your inquiries and consultation requests</li>
            <li>To process enrollment in our programs (such as the Diabetes Reversal Shared Medical Appointment program)</li>
            <li>To communicate with you about your care, appointments, or program participation</li>
            <li>To send you health-related information, newsletters, or updates you have opted into</li>
            <li>To improve the Site and user experience</li>
            <li>To comply with legal obligations</li>
          </ul>
          <p class="mt-4">
            <strong>Important:</strong> Any protected health information (PHI) collected through this Site is handled in accordance with our <a href="/notice-of-privacy-practices">Notice of Privacy Practices</a> and applicable HIPAA regulations. Please review that document for details on how your health information is used and protected.
          </p>
        </div>

        <!-- Section 3 -->
        <div>
          <h2 id="how-we-share" class="text-h2 font-serif text-brand-900 mb-4 pt-4 border-t border-neutral-100">3. How We Share Your Information</h2>
          <p>We do not sell your personal information. We may share your information with:</p>
          <ul>
            <li><strong>Service providers</strong> who help us operate the Site and manage our practice (such as our CRM platform, email service provider, and web hosting provider). These providers are contractually required to protect your information and use it only for the purposes we specify.</li>
            <li><strong>Healthcare-related parties</strong> as permitted or required under HIPAA (see our Notice of Privacy Practices)</li>
            <li><strong>Legal authorities</strong> when required by law, regulation, or legal process</li>
          </ul>

          <h3 class="text-h4 font-serif text-brand-900 mt-6 mb-2">Third-Party Service Providers</h3>
          <p>We currently use the following third-party services that may receive your data:</p>
          <ul>
            <li><strong>GoHighLevel (GHL):</strong> Customer relationship management platform used to process form submissions and manage communications</li>
            <li><strong>Cloudflare:</strong> Website hosting and performance</li>
            <li><strong>Google Workspace:</strong> Email communications</li>
          </ul>
          <p class="mt-4">Each provider maintains its own privacy policy and data handling practices.</p>
        </div>

        <!-- Section 4 -->
        <div>
          <h2 id="cookies" class="text-h2 font-serif text-brand-900 mb-4 pt-4 border-t border-neutral-100">4. Cookies and Tracking Technologies</h2>
          <p>Our Site may use cookies and similar technologies to:</p>
          <ul>
            <li>Remember your preferences</li>
            <li>Analyze Site traffic and usage patterns</li>
            <li>Improve Site functionality</li>
          </ul>
          <p class="mt-4">You can control cookies through your browser settings. Disabling cookies may affect certain features of the Site.</p>
          <p class="mt-4">We may use Google Analytics or similar analytics tools. These services collect anonymized usage data and are governed by their own privacy policies.</p>
        </div>

        <!-- Section 5 -->
        <div>
          <h2 id="data-security" class="text-h2 font-serif text-brand-900 mb-4 pt-4 border-t border-neutral-100">5. Data Security</h2>
          <p>We implement reasonable administrative, technical, and physical safeguards to protect your information, including:</p>
          <ul>
            <li>SSL/TLS encryption on all Site pages</li>
            <li>Access controls on systems that store personal information</li>
            <li>HIPAA-compliant handling of any protected health information</li>
          </ul>
          <p class="mt-4">No method of transmission over the internet is 100% secure. While we strive to protect your information, we cannot guarantee absolute security.</p>
        </div>

        <!-- Section 6 -->
        <div>
          <h2 id="data-retention" class="text-h2 font-serif text-brand-900 mb-4 pt-4 border-t border-neutral-100">6. Data Retention</h2>
          <p>We retain personal information for as long as necessary to fulfill the purposes described in this policy, comply with legal obligations, resolve disputes, and enforce our agreements. Health-related records are retained in accordance with applicable state and federal requirements.</p>
        </div>

        <!-- Section 7 -->
        <div>
          <h2 id="your-rights" class="text-h2 font-serif text-brand-900 mb-4 pt-4 border-t border-neutral-100">7. Your Rights and Choices</h2>
          <p>Depending on your location, you may have certain rights regarding your personal information, including:</p>
          <ul>
            <li>The right to access the personal information we hold about you</li>
            <li>The right to request correction of inaccurate information</li>
            <li>The right to request deletion of your information (subject to legal retention requirements)</li>
            <li>The right to opt out of marketing communications at any time</li>
          </ul>
          <p class="mt-4">For rights related to your protected health information, please see our <a href="/notice-of-privacy-practices">Notice of Privacy Practices</a>.</p>
          <p class="mt-4">To exercise any of these rights, contact us at <a href="mailto:info@bethmotleymd.com">info@bethmotleymd.com</a> or call <a href="tel:+18642717761">(864) 271-7761</a>.</p>
        </div>

        <!-- Section 8 -->
        <div>
          <h2 id="childrens-privacy" class="text-h2 font-serif text-brand-900 mb-4 pt-4 border-t border-neutral-100">8. Children's Privacy</h2>
          <p>This Site is not directed at children under 13 years of age. We do not knowingly collect personal information from children under 13. If we become aware that we have collected information from a child under 13, we will take steps to delete it promptly.</p>
        </div>

        <!-- Section 9 -->
        <div>
          <h2 id="third-party-links" class="text-h2 font-serif text-brand-900 mb-4 pt-4 border-t border-neutral-100">9. Third-Party Links</h2>
          <p>Our Site may contain links to third-party websites. We are not responsible for the privacy practices or content of those sites. We encourage you to review the privacy policies of any site you visit.</p>
        </div>

        <!-- Section 10 -->
        <div>
          <h2 id="changes" class="text-h2 font-serif text-brand-900 mb-4 pt-4 border-t border-neutral-100">10. Changes to This Privacy Policy</h2>
          <p>We may update this Privacy Policy from time to time. When we do, we will revise the "Effective Date" at the top of this page. We encourage you to review this policy periodically. Continued use of the Site after changes constitutes acceptance of the updated policy.</p>
        </div>

        <!-- Section 11 -->
        <div>
          <h2 id="contact" class="text-h2 font-serif text-brand-900 mb-4 pt-4 border-t border-neutral-100">11. Contact Us</h2>
          <p>If you have questions about this Privacy Policy or how your information is handled, please contact us:</p>
          <p class="mt-4">
            <strong>Beth Motley, MD</strong><br />
            Email: <a href="mailto:info@bethmotleymd.com">info@bethmotleymd.com</a><br />
            Phone: <a href="tel:+18642717761">(864) 271-7761</a>
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
