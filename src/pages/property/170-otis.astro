---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';

const PHONE_NUMBER = 'PHONE_NUMBER_HERE'; // Replace with Vapi phone number after setup
const PHONE_DISPLAY = '(864) XXX-XXXX'; // Replace with formatted Vapi number
---

<BaseLayout
  title="Build-Ready Lot for Sale | 170 Otis St, Greenville, SC 29605"
  description="7,082 sq ft vacant residential lot in Greenville, SC. Cleared, graded, all utilities. $325,000. Homes nearby selling for $1M+."
>
  <!-- Hero -->
  <section class="bg-brand-900 py-16 md:py-24">
    <div class="container-page text-center">
      <span class="mb-6 inline-block inline-flex items-center px-3 py-1 rounded-full text-small font-medium border bg-brand-800 text-brand-200 border-brand-600">
        For Sale — Vacant Lot
      </span>
      <h1 class="text-h1 md:text-display font-serif text-white mb-4">
        170 Otis Street
      </h1>
      <p class="text-body-lg text-brand-200 max-w-2xl mx-auto mb-2">
        Greenville, SC 29605
      </p>
      <p class="text-h2 font-serif text-lime-400 mb-8">
        $325,000
      </p>
      <a
        href={`tel:${PHONE_NUMBER}`}
        class="inline-flex items-center gap-2 px-8 py-4 bg-lime-500 text-brand-900 font-semibold rounded-full text-body-lg hover:bg-lime-400 transition-colors"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Call Alex — {PHONE_DISPLAY}
      </a>
    </div>
  </section>

  <!-- Photo Gallery -->
  <section class="section-padding bg-white">
    <div class="container-page">
      <h2 class="text-h2 font-serif text-brand-900 text-center mb-10">The Lot</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="md:col-span-2">
          <img
            src="/images/property/lot-street-view.jpg"
            alt="170 Otis Street lot - street view showing cleared, graded lot between existing homes"
            class="w-full h-64 md:h-96 object-cover rounded-2xl"
            loading="eager"
          />
        </div>
        <img
          src="/images/property/lot-rear-view.jpg"
          alt="170 Otis Street lot - rear view showing cleared lot with mature trees on perimeter"
          class="w-full h-56 object-cover rounded-2xl"
          loading="lazy"
        />
        <img
          src="/images/property/lot-inspo.jpg"
          alt="Architectural rendering of upscale homes that could be built on the lot"
          class="w-full h-56 object-cover rounded-2xl"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- Key Facts -->
  <section class="section-padding bg-brand-50">
    <div class="container-page">
      <h2 class="text-h2 font-serif text-brand-900 text-center mb-10">Property Details</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="bg-white rounded-2xl p-6 text-center shadow-sm">
          <p class="text-h3 font-serif text-brand-700">7,082</p>
          <p class="text-small text-neutral-500 mt-1">Square Feet</p>
        </div>
        <div class="bg-white rounded-2xl p-6 text-center shadow-sm">
          <p class="text-h3 font-serif text-brand-700">0.163</p>
          <p class="text-small text-neutral-500 mt-1">Acres</p>
        </div>
        <div class="bg-white rounded-2xl p-6 text-center shadow-sm">
          <p class="text-h3 font-serif text-brand-700">RN-D</p>
          <p class="text-small text-neutral-500 mt-1">Zoning</p>
        </div>
        <div class="bg-white rounded-2xl p-6 text-center shadow-sm">
          <p class="text-h3 font-serif text-brand-700">~46'</p>
          <p class="text-small text-neutral-500 mt-1">Road Frontage</p>
        </div>
      </div>

      <!-- Features list -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-12">
        <div>
          <h3 class="text-h4 font-serif text-brand-900 mb-4">Ready to Build</h3>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-lime-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-body text-neutral-700">Cleared and graded — no demolition needed</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-lime-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-body text-neutral-700">City-approved subdivision plat (SSD 25-1165)</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-lime-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-body text-neutral-700">Not in a flood zone — no flood insurance required</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-lime-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-body text-neutral-700">Mature trees on perimeter for natural screening</span>
            </li>
          </ul>
        </div>
        <div>
          <h3 class="text-h4 font-serif text-brand-900 mb-4">All Utilities at the Street</h3>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-lime-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-body text-neutral-700">City water</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-lime-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-body text-neutral-700">City sewer</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-lime-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-body text-neutral-700">Electric</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-lime-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-body text-neutral-700">Natural gas</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Comparable Sale / Value Proposition -->
  <section class="section-padding bg-white">
    <div class="container-page">
      <div class="bg-brand-900 rounded-2xl p-8 md:p-12 text-center">
        <p class="text-small font-medium text-brand-300 uppercase tracking-wider mb-3">
          Comparable Sale — Same Neighborhood
        </p>
        <p class="text-h1 font-serif text-white mb-2">$1,037,500</p>
        <p class="text-body-lg text-brand-200 mb-6">
          102 Elm St, Greenville, SC 29605 — Sold January 2026
        </p>
        <p class="text-body text-brand-200 max-w-2xl mx-auto mb-2">
          4 beds &bull; 4 baths &bull; 2,728 sq ft finished home
        </p>
        <div class="border-t border-brand-700 mt-8 pt-8">
          <p class="text-h3 font-serif text-lime-400 mb-2">Build equity from day one</p>
          <p class="text-body text-brand-200 max-w-xl mx-auto">
            At $325,000 for the lot, a $400–500K build puts you in a $1M+ neighborhood
            for $725–825K total investment. That's significant built-in equity.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Location & Neighborhood -->
  <section class="section-padding bg-brand-50">
    <div class="container-page">
      <h2 class="text-h2 font-serif text-brand-900 text-center mb-4">Location</h2>
      <p class="text-body-lg text-neutral-500 text-center max-w-2xl mx-auto mb-10">
        Established residential neighborhood near downtown Greenville — one of the fastest-growing cities in the Southeast.
      </p>
      <div class="rounded-2xl overflow-hidden shadow-sm h-80 bg-neutral-100">
        <iframe
          title="170 Otis St, Greenville, SC 29605 Map"
          width="100%"
          height="100%"
          style="border:0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          src="https://www.google.com/maps/embed/v1/place?key=AIzaSyBFw0Qbyq9zTFTd-tUY6dZWTgaQzuU17R8&q=170+Otis+St,+Greenville,+SC+29605&zoom=16&maptype=satellite"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-24 bg-brand-900">
    <div class="container-page text-center">
      <h2 class="text-h2 font-serif text-white mb-4">Ready to Make an Offer?</h2>
      <p class="text-body-lg text-brand-200 max-w-xl mx-auto mb-8">
        Call Alex, our property specialist, to discuss the lot, ask questions, or make an offer. Available to take your call now.
      </p>
      <a
        href={`tel:${PHONE_NUMBER}`}
        class="inline-flex items-center gap-2 px-8 py-4 bg-lime-500 text-brand-900 font-semibold rounded-full text-body-lg hover:bg-lime-400 transition-colors"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Call Alex — {PHONE_DISPLAY}
      </a>
      <p class="text-small text-brand-400 mt-4">
        170 Otis St, Greenville, SC 29605 &bull; $325,000 &bull; 7,082 sq ft
      </p>
    </div>
  </section>
</BaseLayout>
