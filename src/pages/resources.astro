---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ResourceCard from '../components/ResourceCard.astro';
import NewsletterForm from '../components/NewsletterForm';
import data from '../../content/pages/resources.json';

const d = data;

/* Pillar icon SVGs keyed by id */
const pillarIcons: Record<string, string> = {
  nutrition:   `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" /></svg>`,
  movement:    `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
  sleep:       `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" /></svg>`,
  stress:      `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" /></svg>`,
  substances:  `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>`,
  connection:  `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>`,
};

/* Pillar color map for left-border accent + pill nav */
const pillarColors: Record<string, { border: string; pill: string; pillActive: string; icon: string }> = {
  green:  { border: 'border-l-emerald-500', pill: 'hover:bg-emerald-50 hover:text-emerald-700', pillActive: 'bg-emerald-50 text-emerald-700 border-emerald-200', icon: 'text-emerald-600' },
  amber:  { border: 'border-l-amber-500',   pill: 'hover:bg-amber-50 hover:text-amber-700',   pillActive: 'bg-amber-50 text-amber-700 border-amber-200',   icon: 'text-amber-600' },
  indigo: { border: 'border-l-indigo-500',   pill: 'hover:bg-indigo-50 hover:text-indigo-700', pillActive: 'bg-indigo-50 text-indigo-700 border-indigo-200', icon: 'text-indigo-600' },
  teal:   { border: 'border-l-teal-500',     pill: 'hover:bg-teal-50 hover:text-teal-700',     pillActive: 'bg-teal-50 text-teal-700 border-teal-200',     icon: 'text-teal-600' },
  slate:  { border: 'border-l-slate-500',    pill: 'hover:bg-slate-50 hover:text-slate-700',   pillActive: 'bg-slate-100 text-slate-700 border-slate-200',  icon: 'text-slate-600' },
  rose:   { border: 'border-l-rose-500',     pill: 'hover:bg-rose-50 hover:text-rose-700',     pillActive: 'bg-rose-50 text-rose-700 border-rose-200',     icon: 'text-rose-600' },
};

/* Collect Beth's picks from all pillars */
const bethPicks = d.pillars.flatMap((p) =>
  p.resources.filter((r) => r.bethPick).map((r) => ({ ...r, pillarLabel: p.label, pillarColor: p.color }))
);
---

<BaseLayout
  title={d.seo.title}
  description={d.seo.description}
>
  <!-- Hero -->
  <Hero
    badge={d.hero.badge}
    headline={d.hero.headline}
    subheadline={d.hero.subheadline}
  >
    <!-- Pillar pill nav -->
    <nav class="mt-10 flex flex-wrap justify-center gap-3" aria-label="Jump to pillar">
      {d.pillars.map((p) => {
        const colors = pillarColors[p.color];
        return (
          <a
            href={`#${p.id}`}
            class:list={[
              "inline-flex items-center gap-2 px-4 py-2 rounded-full text-small font-medium border transition-all duration-200",
              colors.pillActive,
            ]}
          >
            <span class={colors.icon} set:html={pillarIcons[p.id]} />
            {p.label}
          </a>
        );
      })}
    </nav>
  </Hero>

  <!-- Pillar sections -->
  {d.pillars.map((pillar) => {
    const colors = pillarColors[pillar.color];
    return (
      <section id={pillar.id} class="section-padding scroll-mt-24">
        <div class="container-page">
          <!-- Section header with left accent border -->
          <div class:list={["border-l-4 pl-5 mb-10", colors.border]}>
            <div class="flex items-center gap-3 mb-2">
              <span class={colors.icon} set:html={pillarIcons[pillar.id]} />
              <h2 class="text-h2 font-serif text-brand-900">{pillar.label}</h2>
            </div>
          </div>

          <!-- Card grid -->
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
            {pillar.resources.map((resource) => (
              <ResourceCard
                title={resource.title}
                type={resource.type}
                href={resource.href}
                badges={resource.badges}
                bethPick={resource.bethPick}
                description={resource.description}
              />
            ))}
          </div>
        </div>
      </section>
    );
  })}

  <!-- Beth's Picks -->
  <section class="section-padding bg-brand-50/50">
    <div class="container-page">
      <SectionHeading
        title={d.bethPicks.title}
        subtitle={d.bethPicks.subtitle}
        tag={d.bethPicks.badge}
      />
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {bethPicks.map((resource) => (
          <ResourceCard
            title={resource.title}
            type={resource.type}
            href={resource.href}
            badges={resource.badges}
            bethPick={true}
            description={resource.description}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ACLM Official Resources -->
  <section class="section-padding">
    <div class="container-page">
      <SectionHeading
        title={d.aclm.title}
        subtitle={d.aclm.subtitle}
      />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {d.aclm.items.map((item) => (
          <a
            href={item.href}
            target="_blank"
            rel="noopener noreferrer"
            class="card text-center hover:border-brand-200 transition-all group"
          >
            <div class="w-12 h-12 rounded-full bg-brand-100 flex items-center justify-center mx-auto mb-4 group-hover:bg-brand-200 transition-colors">
              <svg class="w-6 h-6 text-brand-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
            </div>
            <h3 class="text-h4 font-serif text-brand-900 mb-2 group-hover:text-brand-700 transition-colors">{item.title}</h3>
            <p class="text-small text-neutral-600">{item.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="bg-brand-900 py-16 md:py-24">
    <div class="container-page text-center">
      <h2 class="text-h2 font-serif text-white mb-4">{d.newsletter.title}</h2>
      <p class="text-body-lg text-brand-300 max-w-xl mx-auto mb-8">
        {d.newsletter.description}
      </p>
      <div class="flex justify-center">
        <NewsletterForm client:visible dark={true} />
      </div>
    </div>
  </section>
</BaseLayout>
