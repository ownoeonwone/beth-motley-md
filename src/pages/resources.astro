---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ResourceCard from '../components/ResourceCard.astro';
import NewsletterForm from '../components/NewsletterForm';
import { getResourcesPage } from '../lib/sanity';

const d = await getResourcesPage();

const pillarIcons: Record<string, string> = {
  nutrition:  `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" /></svg>`,
  movement:   `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
  sleep:      `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" /></svg>`,
  stress:     `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" /></svg>`,
  substances: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>`,
  connection: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>`,
};

const pillarColors: Record<string, { border: string; pillActive: string; icon: string; dot: string }> = {
  green:  { border: 'border-l-emerald-400', pillActive: 'bg-emerald-50 text-emerald-700 border-emerald-200', icon: 'text-emerald-600', dot: 'bg-emerald-400' },
  amber:  { border: 'border-l-amber-400',   pillActive: 'bg-amber-50 text-amber-700 border-amber-200',     icon: 'text-amber-600',   dot: 'bg-amber-400' },
  indigo: { border: 'border-l-indigo-400',  pillActive: 'bg-indigo-50 text-indigo-700 border-indigo-200', icon: 'text-indigo-600',  dot: 'bg-indigo-400' },
  teal:   { border: 'border-l-teal-400',    pillActive: 'bg-teal-50 text-teal-700 border-teal-200',       icon: 'text-teal-600',    dot: 'bg-teal-400' },
  slate:  { border: 'border-l-slate-400',   pillActive: 'bg-slate-100 text-slate-700 border-slate-200',   icon: 'text-slate-600',   dot: 'bg-slate-400' },
  rose:   { border: 'border-l-rose-400',    pillActive: 'bg-rose-50 text-rose-700 border-rose-200',       icon: 'text-rose-600',    dot: 'bg-rose-400' },
};
---

<BaseLayout
  title={d.seo.title}
  description={d.seo.description}
>
  <!-- Hero -->
  <Hero
    badge={d.hero.badge}
    headline={d.hero.headline}
    subheadline={d.hero.subheadline}
  >
    <!-- Pillar nav -->
    <nav class="mt-8 flex flex-wrap justify-center gap-2" aria-label="Jump to pillar">
      {d.pillars.map((p) => {
        const colors = pillarColors[p.color];
        return (
          <a
            href={`#${p.id}`}
            class:list={[
              "inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full text-xs font-semibold border transition-all duration-200",
              colors.pillActive,
            ]}
          >
            <span class={colors.icon} set:html={pillarIcons[p.id]} />
            {p.label}
          </a>
        );
      })}
    </nav>

    <!-- Legend -->
    <p class="mt-5 text-xs text-neutral-400 text-center">
      <svg class="w-3 h-3 fill-amber-500 inline mr-1 -mt-px" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
      Dr. Motley's Pick: resources she recommends most often in practice
    </p>
  </Hero>

  <!-- Pillar sections -->
  <div class="py-16 md:py-20">
    <div class="container-page">
      <div class="max-w-3xl mx-auto space-y-16">
        {d.pillars.map((pillar) => {
          const colors = pillarColors[pillar.color];
          return (
            <section id={pillar.id} class="scroll-mt-24">
              <!-- Section header -->
              <div class:list={["border-l-[3px] pl-4 mb-6", colors.border]}>
                <div class="flex items-center gap-2 mb-0.5">
                  <span class={colors.icon} set:html={pillarIcons[pillar.id]} />
                  <h2 class="text-lg font-semibold text-brand-900">{pillar.label}</h2>
                </div>
                <p class="text-sm text-neutral-500">{pillar.subtitle}</p>
              </div>

              <!-- Resource list -->
              <div>
                {pillar.resources.map((resource) => (
                  <ResourceCard
                    title={resource.title}
                    type={resource.type}
                    href={resource.href}
                    bethPick={resource.bethPick}
                    description={resource.description}
                  />
                ))}
              </div>
            </section>
          );
        })}
      </div>
    </div>
  </div>

  <!-- ACLM Official Resources -->
  <section class="border-t border-neutral-100 py-14 md:py-16">
    <div class="container-page">
      <div class="max-w-3xl mx-auto">
        <div class="mb-8">
          <p class="text-xs font-semibold uppercase tracking-widest text-neutral-400 mb-1">{d.aclm.subtitle}</p>
          <h2 class="text-xl font-semibold text-brand-900">{d.aclm.title}</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {d.aclm.items.map((item) => (
            <a
              href={item.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group rounded-lg border border-neutral-100 bg-white p-5 hover:border-brand-200 hover:shadow-sm transition-all duration-200"
            >
              <h3 class="text-sm font-semibold text-brand-900 group-hover:text-brand-700 transition-colors mb-2 flex items-center gap-1.5">
                {item.title}
                <svg class="w-3.5 h-3.5 text-neutral-300 group-hover:text-brand-400 transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </h3>
              <p class="text-xs text-neutral-500 leading-relaxed">{item.description}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Provider Tools & Training -->
  <section class="bg-neutral-50 border-t border-neutral-100 py-14 md:py-16">
    <div class="container-page">
      <div class="max-w-3xl mx-auto">

        <!-- Header -->
        <div class="mb-8">
          <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[11px] font-bold uppercase tracking-widest bg-brand-100 text-brand-700 border border-brand-200 mb-3">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
            {d.providers.badge}
          </span>
          <h2 class="text-xl font-semibold text-brand-900 mb-1">{d.providers.title}</h2>
          <p class="text-sm text-neutral-500">{d.providers.subtitle}</p>
        </div>

        <!-- Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {d.providers.items.map((item) => {
            const isVideo = item.icon === 'video';
            return (
              <div class="group bg-white rounded-xl border border-neutral-200 p-6 flex flex-col hover:border-brand-200 hover:shadow-md transition-all duration-300">

                <!-- Icon + platform -->
                <div class="flex items-center gap-3 mb-5">
                  <div class:list={[
                    "w-10 h-10 rounded-lg flex items-center justify-center shrink-0",
                    isVideo ? "bg-violet-50" : "bg-brand-50",
                  ]}>
                    {isVideo ? (
                      <svg class="w-5 h-5 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.348a1.125 1.125 0 010 1.971l-11.54 6.347a1.125 1.125 0 01-1.667-.985V5.653z" />
                      </svg>
                    ) : (
                      <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
                      </svg>
                    )}
                  </div>
                  <span class="text-xs font-semibold text-neutral-400 tracking-wide">{item.platform}</span>
                </div>

                <!-- Content -->
                <div class="flex-1">
                  <h3 class="text-[15px] font-semibold text-brand-900 mb-2 leading-snug">{item.title}</h3>
                  <p class="text-sm text-neutral-500 leading-relaxed">{item.description}</p>
                </div>

                <!-- CTA -->
                <a
                  href={item.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class:list={[
                    "mt-6 inline-flex items-center gap-2 text-sm font-semibold transition-colors duration-200",
                    isVideo ? "text-violet-600 hover:text-violet-700" : "text-brand-600 hover:text-brand-700",
                  ]}
                >
                  {item.cta}
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>

              </div>
            );
          })}
        </div>

      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="bg-brand-900 py-16 md:py-20">
    <div class="container-page text-center">
      <h2 class="text-h2 font-serif text-white mb-4">{d.newsletter.title}</h2>
      <p class="text-body-lg text-brand-300 max-w-xl mx-auto mb-8">
        {d.newsletter.description}
      </p>
      <div class="flex justify-center">
        <NewsletterForm client:visible dark={true} />
      </div>
    </div>
  </section>
</BaseLayout>
