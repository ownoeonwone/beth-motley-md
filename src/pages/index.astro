---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CredentialBar from '../components/CredentialBar.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ProgramCard from '../components/ProgramCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import NewsletterForm from '../components/NewsletterForm';
import EventsCalendar from '../components/EventsCalendar';
import { getHomePage } from '../lib/sanity';

const calendarId = import.meta.env.PUBLIC_GOOGLE_CALENDAR_ID || '';
const apiKey = import.meta.env.PUBLIC_GOOGLE_API_KEY || '';

const pillarIcons = [
  `<svg class="w-8 h-8 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" /></svg>`,
  `<svg class="w-8 h-8 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
  `<svg class="w-8 h-8 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" /></svg>`,
  `<svg class="w-8 h-8 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.182 15.182a4.5 4.5 0 01-6.364 0M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z" /></svg>`,
  `<svg class="w-8 h-8 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>`,
  `<svg class="w-8 h-8 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>`,
];

const d = await getHomePage();
---

<BaseLayout
  title={d.seo.title}
  description={d.seo.description}
>
  <link
    slot="head"
    rel="preload"
    as="image"
    href="/images/headshots/beth-motley-hallway.webp"
    type="image/webp"
  />
  <!-- Hero - text only -->
  <section class="bg-gradient-to-b from-brand-50 to-white py-20 md:py-32">
    <div class="container-page text-center max-w-4xl">
      <span class="badge mb-6 inline-block">{d.hero.badge}</span>
      <h1 class="font-serif text-h1 md:text-display text-brand-900">
        {d.hero.headline}
      </h1>
      <p class="mt-6 text-body-lg text-neutral-600 max-w-2xl mx-auto">
        {d.hero.subheadline}
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href={d.hero.primaryCta.href} class="btn-primary">{d.hero.primaryCta.text}</a>
        <a href={d.hero.secondaryCta.href} class="btn-secondary">{d.hero.secondaryCta.text}</a>
      </div>
    </div>
  </section>

  <!-- Dr. Motley Photo -->
  <section class="bg-white">
    <div class="container-page max-w-5xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center py-12 md:py-16">
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <picture>
            <source srcset="/images/headshots/beth-motley-hallway.webp" type="image/webp" />
            <img
              src={d.doctorIntro.image}
              alt={d.doctorIntro.imageAlt}
              class="w-full h-auto"
              width="800"
              height="1200"
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          </picture>
        </div>
        <div class="text-center md:text-left">
          <h2 class="font-serif text-h2 text-brand-900 mb-4">{d.doctorIntro.name}</h2>
          <p class="text-body-lg text-neutral-600 mb-6">
            {d.doctorIntro.bio}
          </p>
          <a href={d.doctorIntro.linkHref} class="inline-flex items-center text-body font-medium text-brand-600 hover:text-brand-800 transition-colors group">
            {d.doctorIntro.linkText}
            <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Credential Bar -->
  <CredentialBar />

  <!-- What Is Lifestyle Medicine? -->
  <section class="section-padding">
    <div class="container-page">
      <SectionHeading
        title={d.lifestyleMedicine.title}
        subtitle={d.lifestyleMedicine.subtitle}
        tag={d.lifestyleMedicine.tag}
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {d.lifestyleMedicine.pillars.map((pillar, i) => (
          <div class="card text-center hover:border-brand-200 transition-colors">
            <div class="w-14 h-14 rounded-full bg-brand-50 flex items-center justify-center mx-auto mb-4">
              <Fragment set:html={pillarIcons[i] || pillarIcons[0]} />
            </div>
            <h3 class="text-h4 font-serif text-brand-900 mb-2">{pillar.title}</h3>
            <p class="text-body text-neutral-600">{pillar.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Programs -->
  <section class="section-padding bg-brand-50/50">
    <div class="container-page">
      <SectionHeading
        title={d.programs.title}
        subtitle={d.programs.subtitle}
        tag={d.programs.tag}
      />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {d.programs.items.map((program) => (
          <ProgramCard
            title={program.title}
            description={program.description}
            href={program.href}
            icon={program.icon}
            features={program.features}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- About Preview -->
  <section class="section-padding">
    <div class="container-page">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="aspect-[4/5] rounded-2xl overflow-hidden order-2 lg:order-1">
          <picture>
            <source srcset="/images/headshots/beth-motley-black-blazer.webp" type="image/webp" />
            <img
              src={d.aboutPreview.image}
              alt={d.aboutPreview.imageAlt}
              class="w-full h-full object-cover"
              width="1792"
              height="2176"
              loading="lazy"
              decoding="async"
            />
          </picture>
        </div>
        <div class="order-1 lg:order-2">
          <span class="badge mb-4 inline-block">{d.aboutPreview.tag}</span>
          <h2 class="text-h2 font-serif text-brand-900 mb-6">{d.aboutPreview.headline}</h2>
          {d.aboutPreview.paragraphs.map((p, i) => (
            <p class={`${i === 0 ? 'text-body-lg' : 'text-body'} text-neutral-600 mb-6`}>
              {p}
            </p>
          ))}
          <div class="flex flex-wrap gap-2 mb-8">
            {d.aboutPreview.badges.map((badge) => (
              <span class="badge">{badge}</span>
            ))}
          </div>
          <a href={d.aboutPreview.linkHref} class="inline-flex items-center text-body font-medium text-brand-600 hover:text-brand-800 transition-colors group">
            {d.aboutPreview.linkText}
            <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section-padding bg-brand-50/50">
    <div class="container-page">
      <SectionHeading
        title={d.testimonials.title}
        subtitle={d.testimonials.subtitle}
        tag={d.testimonials.tag}
      />
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {d.testimonials.items.map((t) => (
          <TestimonialCard
            quote={t.quote}
            name={t.name}
            role={t.role}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Upcoming Events -->
  <section class="section-padding bg-white">
    <div class="container-page max-w-4xl">
      <SectionHeading
        title="Upcoming Events"
        subtitle="Next diabetes reversal cohort dates, speaking engagements, and more."
        tag="What's Coming Up"
      />
      <EventsCalendar
        calendarId={calendarId}
        apiKey={apiKey}
        limit={3}
        showFeatured={false}
        showMonthHeaders={false}
        compact={true}
        client:visible
      />
      <div class="text-center mt-8">
        <a href="/events" class="inline-flex items-center text-body font-medium text-brand-600 hover:text-brand-800 transition-colors group">
          View all events & programs
          <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Pear Down Community -->
  <section class="section-padding bg-white">
    <div class="container-page">
      <div class="max-w-4xl mx-auto bg-gradient-to-br from-brand-50 to-lime-50 rounded-3xl p-8 md:p-12 lg:p-16 text-center">
        <span class="badge mb-4 inline-block">{d.community.tag}</span>
        <h2 class="text-h2 font-serif text-brand-900 mb-4">{d.community.title}</h2>
        <p class="text-body-lg text-neutral-600 max-w-2xl mx-auto mb-4">
          {d.community.description}
        </p>
        <p class="text-body text-neutral-500 max-w-xl mx-auto mb-8">
          {d.community.subdescription}
        </p>
        <a href={d.community.ctaHref} target="_blank" rel="noopener" class="btn-primary inline-flex items-center gap-2">
          {d.community.ctaText}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="bg-brand-900 py-16 md:py-24">
    <div class="container-page text-center">
      <h2 class="text-h2 font-serif text-white mb-4">{d.newsletter.title}</h2>
      <p class="text-body-lg text-brand-300 max-w-xl mx-auto mb-8">
        {d.newsletter.description}
      </p>
      <div class="flex justify-center">
        <NewsletterForm client:visible dark={true} />
      </div>
    </div>
  </section>
</BaseLayout>
