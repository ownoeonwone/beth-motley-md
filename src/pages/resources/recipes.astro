---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';

// ── Data ─────────────────────────────────────────────────────────────────────

const sources = [
  {
    name: 'Forks Over Knives',
    url: 'https://www.forksoverknives.com/recipes/',
    tagline: 'The gold standard of whole-food, plant-based, oil-free cooking.',
    strictWFPB: true,
    logo: 'FOK',
    color: 'bg-green-50 border-green-200 text-green-800',
    dot: 'bg-green-500',
  },
  {
    name: 'Physicians Committee (PCRM)',
    url: 'https://www.pcrm.org/good-nutrition/plant-based-diets/recipes',
    tagline: 'Dr. Neal Barnard\'s organization. Medically rigorous, clinically tested recipes.',
    strictWFPB: true,
    logo: 'PCRM',
    color: 'bg-blue-50 border-blue-200 text-blue-800',
    dot: 'bg-blue-500',
  },
  {
    name: 'Rainbow Plant Life',
    url: 'https://rainbowplantlife.com/category/recipes/',
    tagline: 'Nisha Vora\'s big-flavor plant-based recipes. James Beard-nominated and NYT bestselling cookbook author.',
    strictWFPB: false,
    logo: 'RPL',
    color: 'bg-purple-50 border-purple-200 text-purple-800',
    dot: 'bg-purple-500',
  },
  {
    name: 'Minimalist Baker',
    url: 'https://minimalistbaker.com/recipe-index/',
    tagline: '10 ingredients or less, 1 bowl, or 30 minutes. Mostly plant-based — some recipes use small amounts of oil.',
    strictWFPB: false,
    logo: 'MB',
    color: 'bg-amber-50 border-amber-200 text-amber-800',
    dot: 'bg-amber-500',
  },
  {
    name: 'Oh She Glows',
    url: 'https://ohsheglows.com/categories/recipes-2/',
    tagline: 'Angela Liddon\'s fully plant-based site. Elegant, family-friendly, and globally inspired.',
    strictWFPB: false,
    logo: 'OSG',
    color: 'bg-rose-50 border-rose-200 text-rose-800',
    dot: 'bg-rose-400',
  },
  {
    name: 'The Full Helping',
    url: 'https://www.thefullhelping.com/recipe-index/',
    tagline: 'By registered dietitian Gena Hamshaw. Thoughtful, nutrient-dense plant-based recipes.',
    strictWFPB: false,
    logo: 'TFH',
    color: 'bg-teal-50 border-teal-200 text-teal-800',
    dot: 'bg-teal-500',
  },
];

// Unsplash CDN: w=600, h=300, q=75, auto=format (serves WebP to supporting browsers)
const IMG = (id: string) =>
  `https://images.unsplash.com/photo-${id}?auto=format&fit=crop&w=600&h=300&q=75`;

const recipes = [
  // ── BREAKFAST ───────────────────────────────────────────────────────────────
  {
    category: 'breakfast',
    title: 'Overnight Oats — Full Collection',
    source: 'Forks Over Knives',
    href: 'https://www.forksoverknives.com/recipes/vegan-breakfast/easy-overnight-chia-oatmeal/',
    description: 'Six variations on the easiest WFPB breakfast. Make the night before, no cooking required.',
    tags: ['oil-free', 'no-cook', 'high-fiber'],
    bethPick: true,
    isCollection: false,
    image: IMG('1517673132405-a56a933b52d1'),
  },
  {
    category: 'breakfast',
    title: 'Tofu Scramble',
    source: 'Forks Over Knives',
    href: 'https://www.forksoverknives.com/recipes/vegan-breakfast/10-minute-tofu-scramble/',
    description: 'The plant-based answer to scrambled eggs. High-protein, oil-free, and endlessly customizable.',
    tags: ['oil-free', 'high-protein'],
    bethPick: false,
    isCollection: false,
    image: IMG('1525351326368-efbb5cb6814d'),
  },
  {
    category: 'breakfast',
    title: 'Banana Oat Pancakes',
    source: 'Minimalist Baker',
    href: 'https://minimalistbaker.com/1-bowl-vegan-banana-oat-pancakes/',
    description: '1 bowl, 7 ingredients, no refined flour. Naturally sweet from banana — skip the oil by using a non-stick pan.',
    tags: ['gluten-free option', 'no refined sugar'],
    bethPick: false,
    isCollection: false,
    image: IMG('1565299543923-37dd37887442'),
  },
  {
    category: 'breakfast',
    title: 'WFPB Breakfast Collection',
    source: 'Physicians Committee (PCRM)',
    href: 'https://www.pcrm.org/good-nutrition/plant-based-diets/recipes',
    description: 'Dr. Barnard\'s team-curated breakfasts: oatmeal bowls, savory tofu dishes, smoothies, and more.',
    tags: ['oil-free', 'clinically tested'],
    bethPick: false,
    isCollection: true,
    image: IMG('1504674900247-0877df9cc836'),
  },
  {
    category: 'breakfast',
    title: 'Healthy Breakfast Cookies',
    source: 'Rainbow Plant Life',
    href: 'https://rainbowplantlife.com/healthy-vegan-breakfast-cookies/',
    description: 'Oats, seeds, and almond butter — healthy enough for breakfast, delicious enough for dessert. 5g protein per cookie.',
    tags: ['high-fiber', 'portable', 'meal-prep'],
    bethPick: false,
    isCollection: false,
    image: IMG('1490645935967-10de6ba17061'),
  },
  {
    category: 'breakfast',
    title: 'Savory Loaded Lunchtime Oatmeal',
    source: 'Oh She Glows',
    href: 'https://ohsheglows.com/loaded-lunchtime-oatmeal/',
    description: 'Proof that oatmeal doesn\'t have to be sweet. Loaded with veggies, beans, and savory toppings — deeply satisfying.',
    tags: ['high-fiber', 'savory', 'iron-rich'],
    bethPick: true,
    isCollection: false,
    image: IMG('1478145046317-c8a31a5a99c4'),
  },

  // ── LUNCH ────────────────────────────────────────────────────────────────────
  {
    category: 'lunch',
    title: 'Chickpea Noodle Soup',
    source: 'Forks Over Knives',
    href: 'https://www.forksoverknives.com/recipes/vegan-soups-stews/30-minute-chickpea-noodle-soup-spinach/',
    description: 'Comfort food, WFPB style. Plant-based take on the classic — hearty, oil-free, and meal-prep friendly.',
    tags: ['oil-free', 'meal-prep', 'comfort food'],
    bethPick: true,
    isCollection: false,
    image: IMG('1547592166-23ac45744acd'),
  },
  {
    category: 'lunch',
    title: 'Lentil Vegetable Soup',
    source: 'Forks Over Knives',
    href: 'https://www.forksoverknives.com/recipes/vegan-soups-stews/lentil-vegetable-soup/',
    description: 'High-protein, high-fiber, incredibly filling. Lentil soups are one of the best things you can eat for blood sugar.',
    tags: ['oil-free', 'blood sugar-friendly', 'high-protein'],
    bethPick: true,
    isCollection: false,
    image: IMG('1547592180-85f173990554'),
  },
  {
    category: 'lunch',
    title: 'Roasted Buddha Bowl',
    source: 'Oh She Glows',
    href: 'https://ohsheglows.com/roasted-buddha-bowl/',
    description: 'Roasted cauliflower and broccoli over quinoa with crispy chickpeas and a cashew lemon-tahini sauce. Endlessly variable.',
    tags: ['meal-prep', 'customizable'],
    bethPick: false,
    isCollection: false,
    image: IMG('1546069901-ba9599a7e63c'),
  },
  {
    category: 'lunch',
    title: 'WFPB Lunch Recipes',
    source: 'Physicians Committee (PCRM)',
    href: 'https://www.pcrm.org/good-nutrition/plant-based-diets/recipes',
    description: 'Wraps, salads, soups, and grain bowls — all designed around clinical nutrition principles.',
    tags: ['oil-free', 'clinically tested'],
    bethPick: false,
    isCollection: true,
    image: IMG('1512621776951-a57141f2eefd'),
  },
  {
    category: 'lunch',
    title: 'Simple Green Salad with Lemon Vinaigrette',
    source: 'Minimalist Baker',
    href: 'https://minimalistbaker.com/simple-green-salad-with-lemon-vinaigrette/',
    description: 'A go-to weekday salad. Fresh, bright, and pairs with anything — ready in 10 minutes.',
    tags: ['quick', '10 ingredients'],
    bethPick: false,
    isCollection: false,
    image: IMG('1540420828-f7be2426f908'),
  },
  {
    category: 'lunch',
    title: 'Creamy White Bean Soup with Kale',
    source: 'Rainbow Plant Life',
    href: 'https://rainbowplantlife.com/creamy-white-bean-soup-with-kale-and-gremolata/',
    description: 'Nourishing and surprisingly creamy — 20g fiber and 17g protein per serving. Perfect for meal prep.',
    tags: ['high-protein', 'meal-prep', 'high-fiber'],
    bethPick: false,
    isCollection: false,
    image: IMG('1588166524941-3bf61a9c41db'),
  },

  // ── DINNER ───────────────────────────────────────────────────────────────────
  {
    category: 'dinner',
    title: 'Lentil Bolognese',
    source: 'Forks Over Knives',
    href: 'https://www.forksoverknives.com/recipes/vegan-pasta-noodles/budget-friendly-lentil-bolognese/',
    description: 'A whole-food pasta sauce with as much protein as the meat version. A staple for good reason.',
    tags: ['oil-free', 'high-protein', 'family-friendly'],
    bethPick: true,
    isCollection: false,
    image: IMG('1621996346565-e3dbc646d9a9'),
  },
  {
    category: 'dinner',
    title: 'Crowd-Pleasing Vegan Caesar Salad',
    source: 'Oh She Glows',
    href: 'https://ohsheglows.com/crowd-pleasing-vegan-caesar-salad/',
    description: 'The most popular salad on Oh She Glows. Cashew-based dressing, roasted chickpea croutons, and nut parmesan — feeds a crowd.',
    tags: ['family-friendly', 'crowd-pleaser', 'high-protein'],
    bethPick: true,
    isCollection: false,
    image: IMG('1512621776951-a57141f2eefd'),
  },
  {
    category: 'dinner',
    title: 'Spicy Red Lentil Curry',
    source: 'Minimalist Baker',
    href: 'https://minimalistbaker.com/spicy-red-lentil-curry/',
    description: '1 pot, 30 minutes, deeply spiced. High in plant protein and fiber, naturally blood sugar-friendly.',
    tags: ['30 minutes', '1 pot', 'blood sugar-friendly'],
    bethPick: false,
    isCollection: false,
    image: IMG('1585937421612-70a008356fbe'),
  },
  {
    category: 'dinner',
    title: 'WFPB Dinner / Entrée Collection',
    source: 'Physicians Committee (PCRM)',
    href: 'https://www.pcrm.org/good-nutrition/plant-based-diets/recipes',
    description: 'Clinician-curated main courses. Each recipe is designed around evidence-based nutrition targets.',
    tags: ['oil-free', 'clinically tested'],
    bethPick: false,
    isCollection: true,
    image: IMG('1476224203421-74177e9911ea'),
  },
  {
    category: 'dinner',
    title: 'Red Lentil Curry',
    source: 'Rainbow Plant Life',
    href: 'https://rainbowplantlife.com/vegan-red-lentil-curry/',
    description: 'The most popular recipe on the site — 1,800+ five-star ratings. Ultra-creamy with coconut milk and almond butter.',
    tags: ['1 pot', 'family-friendly', 'high-protein'],
    bethPick: true,
    isCollection: false,
    image: IMG('1565557539705-cccb1af16c14'),
  },
  {
    category: 'dinner',
    title: 'Butternut Squash Soup with Five Spice',
    source: 'The Full Helping',
    href: 'https://www.thefullhelping.com/creamy-butternut-squash-five-spice-soup/',
    description: 'Creamy without cream, rich without butter. A registered dietitian\'s take on the fall classic.',
    tags: ['seasonal', 'anti-inflammatory'],
    bethPick: false,
    isCollection: false,
    image: IMG('1476718406336-9d2f09be8928'),
  },

  // ── SNACKS ───────────────────────────────────────────────────────────────────
  {
    category: 'snack',
    title: 'Lemony White Bean Dip',
    source: 'Rainbow Plant Life',
    href: 'https://rainbowplantlife.com/lemony-white-bean-dip/',
    description: 'Garlicky, lemony, and creamy — a gourmet alternative to hummus. Quick to make and big on flavor.',
    tags: ['high-protein', '10 ingredients', 'quick'],
    bethPick: true,
    isCollection: false,
    image: IMG('1541519227354-08fa5d50c820'),
  },
  {
    category: 'snack',
    title: 'No-Bake Cookie Energy Bites',
    source: 'Minimalist Baker',
    href: 'https://minimalistbaker.com/5-ingredient-no-bake-cookie-energy-bites/',
    description: 'Oats, nut butter, dates, and seeds. Portable, satisfying, and keeps blood sugar steady.',
    tags: ['no-cook', 'portable', 'blood sugar-friendly'],
    bethPick: false,
    isCollection: false,
    image: IMG('1499028344343-cd173ffc68a9'),
  },
  {
    category: 'snack',
    title: 'WFPB Snack Collection',
    source: 'Forks Over Knives',
    href: 'https://www.forksoverknives.com/recipes/vegan-snacks-appetizers/',
    description: 'Dips, balls, bars, and bites — all oil-free and built from whole foods.',
    tags: ['oil-free', 'variety'],
    bethPick: false,
    isCollection: true,
    image: IMG('1498654896293-37aaf4c906ca'),
  },
  {
    category: 'snack',
    title: 'Actually Crispy Baked Chickpeas',
    source: 'Minimalist Baker',
    href: 'https://minimalistbaker.com/actually-crispy-baked-chickpeas/',
    description: 'Crunchy, protein-rich, and endlessly flavored. Far better than chips and actually filling.',
    tags: ['high-protein', 'crunchy', 'portable'],
    bethPick: true,
    isCollection: false,
    image: IMG('1511690656952-34342bb7c2f2'),
  },
  {
    category: 'snack',
    title: 'Healthy Snack Recipes',
    source: 'Physicians Committee (PCRM)',
    href: 'https://www.pcrm.org/good-nutrition/plant-based-diets/recipes',
    description: 'Clinician-approved snacks: dips, spreads, bites, and drinks that don\'t spike blood sugar.',
    tags: ['oil-free', 'blood sugar-friendly'],
    bethPick: false,
    isCollection: true,
    image: IMG('1505576399279-f19f4df9cb88'),
  },
];

const categories = [
  { id: 'all',       label: 'All Recipes' },
  { id: 'breakfast', label: 'Breakfast'   },
  { id: 'lunch',     label: 'Lunch'       },
  { id: 'dinner',    label: 'Dinner'      },
  { id: 'snack',     label: 'Snacks'      },
];

const tagColors: Record<string, string> = {
  'oil-free':              'bg-green-50 text-green-700 border-green-200',
  'high-protein':          'bg-blue-50 text-blue-700 border-blue-200',
  'blood sugar-friendly':  'bg-lime-50 text-lime-700 border-lime-200',
  'meal-prep':             'bg-violet-50 text-violet-700 border-violet-200',
  'default':               'bg-neutral-50 text-neutral-500 border-neutral-200',
};
---

<BaseLayout
  title="WFPB Recipe Bank | Beth Motley, MD"
  description="Curated whole-food, plant-based recipes from the most trusted sources in lifestyle medicine — Forks Over Knives, PCRM, Minimalist Baker, Oh She Glows, and more. Organized by breakfast, lunch, dinner, and snacks."
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-brand-50 to-white py-16 md:py-24">
    <div class="container-page text-center max-w-3xl">
      <a href="/resources" class="inline-flex items-center gap-1.5 text-small text-brand-600 hover:text-brand-800 font-medium mb-6 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Resources
      </a>
      <span class="mb-4 inline-flex items-center px-3 py-1 rounded-full text-small font-medium border bg-lime-50 text-lime-700 border-lime-200">
        Whole-Food Plant-Based
      </span>
      <h1 class="font-serif text-h1 md:text-display text-brand-900">Recipe Bank</h1>
      <p class="mt-6 text-body-lg text-neutral-600 max-w-2xl mx-auto">
        Curated recipes from the most trusted WFPB sources. Every link here is vetted — no fad diets, no sponsored content, no ingredient lists that require a chemistry degree.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-4 text-small">
        <span class="inline-flex items-center gap-1.5">
          <span class="w-2.5 h-2.5 rounded-full bg-green-500"></span>
          <span class="text-neutral-600">Strictly WFPB / oil-free</span>
        </span>
        <span class="inline-flex items-center gap-1.5">
          <span class="w-2.5 h-2.5 rounded-full bg-amber-400"></span>
          <span class="text-neutral-600">WFPB-friendly (some oil used)</span>
        </span>
        <span class="inline-flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 fill-amber-500" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
          <span class="text-neutral-600">Dr. Motley's Pick</span>
        </span>
      </div>
    </div>
  </section>

  <!-- Category filter + recipe grid -->
  <section class="section-padding bg-white" id="recipes">
    <div class="container-page max-w-5xl">

      <!-- Filter tabs -->
      <div class="flex flex-wrap gap-2 mb-10" id="category-filters" role="group" aria-label="Filter by meal">
        {categories.map((cat, i) => (
          <button
            data-filter={cat.id}
            class:list={[
              "px-5 py-2 rounded-full text-small font-semibold border transition-all duration-200 cursor-pointer",
              i === 0
                ? "bg-brand-700 text-white border-brand-700"
                : "bg-white text-neutral-600 border-neutral-200 hover:border-brand-300 hover:text-brand-700",
            ]}
          >
            {cat.label}
          </button>
        ))}
      </div>

      <!-- Recipe cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5" id="recipe-grid">
        {recipes.map((recipe) => {
          return (
            <a
              href={recipe.href}
              target="_blank"
              rel="noopener noreferrer"
              data-category={recipe.category}
              class="group recipe-card flex flex-col bg-white border border-neutral-100 rounded-xl shadow-sm hover:shadow-md hover:border-brand-200 transition-all duration-300 overflow-hidden"
            >
              <div class="relative w-full h-40 overflow-hidden bg-neutral-100">
                <img
                  src={recipe.image}
                  alt={recipe.title}
                  width="600"
                  height="300"
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
                {recipe.bethPick && (
                  <span class="absolute top-2 right-2 inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-white/90 backdrop-blur-sm text-[11px] font-bold text-amber-600 shadow-sm">
                    <svg class="w-3 h-3 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                    Dr. Motley's Pick
                  </span>
                )}
              </div>

              <div class="flex flex-col p-5 flex-1">
                <div class="flex items-start justify-between gap-3 mb-3">
                  <div class="flex-1 min-w-0">
                    <div class="flex flex-wrap items-center gap-2 mb-1">
                      <span class="text-[11px] font-bold uppercase tracking-widest text-neutral-400">
                        {recipe.source}
                      </span>
                      {recipe.isCollection && (
                        <span class="text-[10px] font-semibold px-1.5 py-0.5 rounded bg-brand-50 text-brand-600 border border-brand-100">
                          Collection
                        </span>
                      )}
                    </div>
                    <h3 class="font-serif text-h4 text-brand-900 group-hover:text-brand-700 transition-colors leading-snug">
                      {recipe.title}
                    </h3>
                  </div>
                  <svg class="w-4 h-4 text-neutral-300 group-hover:text-brand-400 transition-colors flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </div>

                <p class="text-small text-neutral-600 leading-relaxed mb-4 flex-1">{recipe.description}</p>

                <div class="flex flex-wrap gap-1.5">
                  {recipe.tags.map((tag) => (
                    <span class:list={[
                      "text-[10px] font-semibold px-2 py-0.5 rounded-full border",
                      tagColors[tag] || tagColors['default'],
                    ]}>
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </a>
          );
        })}
      </div>

      <!-- Empty state (hidden by default) -->
      <div id="no-results" class="hidden text-center py-16">
        <p class="text-body text-neutral-400">No recipes in this category yet. Check back soon.</p>
      </div>

    </div>
  </section>

  <!-- Trusted Sources -->
  <section class="section-padding bg-brand-50/40">
    <div class="container-page max-w-5xl">
      <SectionHeading
        title="Trusted WFPB Sources"
        subtitle="These are the sites Dr. Motley returns to repeatedly. Each one prioritizes evidence over aesthetics."
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {sources.map((source) => (
          <a
            href={source.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group bg-white rounded-xl border border-neutral-100 p-5 hover:shadow-md hover:border-brand-200 transition-all duration-300 flex flex-col gap-3"
          >
            <div class="flex items-center gap-3">
              <div class:list={["w-10 h-10 rounded-lg flex items-center justify-center text-[11px] font-black tracking-tight border flex-shrink-0", source.color]}>
                {source.logo}
              </div>
              <div class="flex items-center gap-2 flex-wrap">
                <span class="text-[15px] font-semibold text-brand-900 group-hover:text-brand-700 transition-colors leading-tight">
                  {source.name}
                </span>
                <svg class="w-3.5 h-3.5 text-neutral-300 group-hover:text-brand-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </div>
            </div>
            <div class="flex items-center gap-1.5">
              <span class:list={["w-2 h-2 rounded-full flex-shrink-0", source.dot]}></span>
              <span class="text-[11px] font-semibold text-neutral-500">
                {source.strictWFPB ? 'Strictly WFPB / oil-free' : 'WFPB-friendly'}
              </span>
            </div>
            <p class="text-small text-neutral-600 leading-relaxed">{source.tagline}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Suggest a recipe CTA -->
  <section class="section-padding bg-white">
    <div class="container-page max-w-2xl text-center">
      <h2 class="font-serif text-h3 text-brand-900 mb-3">Know a Recipe We Should Add?</h2>
      <p class="text-body text-neutral-600 mb-6">
        This bank grows over time. If you've found a great WFPB recipe that belongs here, send it along.
      </p>
      <a href="/contact" class="btn-primary">Send a Recipe Suggestion</a>
    </div>
  </section>
</BaseLayout>

<!-- Category filter script -->
<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
  const cards   = document.querySelectorAll<HTMLElement>('.recipe-card');
  const noResults = document.getElementById('no-results');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;

      // Update button styles
      buttons.forEach((b) => {
        b.classList.remove('bg-brand-700', 'text-white', 'border-brand-700');
        b.classList.add('bg-white', 'text-neutral-600', 'border-neutral-200');
      });
      btn.classList.add('bg-brand-700', 'text-white', 'border-brand-700');
      btn.classList.remove('bg-white', 'text-neutral-600', 'border-neutral-200');

      // Filter cards
      let visible = 0;
      cards.forEach((card) => {
        const show = filter === 'all' || card.dataset.category === filter;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      if (noResults) noResults.style.display = visible === 0 ? '' : 'none';
    });
  });
</script>
