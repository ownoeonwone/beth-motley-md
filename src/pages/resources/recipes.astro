  { id: 'lunch',     label: 'Lunch'       },
  { id: 'dinner',    label: 'Dinner'      },
  { id: 'snack',     label: 'Snacks'      },
];

const tagColors: Record<string, string> = {
  'oil-free':              'bg-green-50 text-green-700 border-green-200',
  'high-protein':          'bg-blue-50 text-blue-700 border-blue-200',
  'blood sugar-friendly':  'bg-lime-50 text-lime-700 border-lime-200',
  'meal-prep':             'bg-violet-50 text-violet-700 border-violet-200',
  'default':               'bg-neutral-50 text-neutral-500 border-neutral-200',
