---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getResourcesPage } from '../../lib/sanity';

const d = await getResourcesPage();

const podcastItem = {
  icon: 'audio',
  platform: 'Apple Podcasts',
  title: "Plant-Based Medicine: Dr. Beth Motley's Journey to Lifestyle Medicine",
  description: "Listen to Dr. Beth discuss pathways into lifestyle medicine, practical clinical strategies, and the evidence behind plant-based approaches.",
  href: 'https://podcasts.apple.com/us/podcast/plant-based-medicine-dr-beth-motleys-journey-to-lifestyle/id1795530614?i=1000691113235',
  cta: 'Listen on Apple Podcasts',
};

const allItems = [...(d.providers?.items || []), podcastItem];
---

<BaseLayout
  title="Provider Tools & Training | Beth Motley, MD"
  description="Resources for clinicians and learners looking to incorporate lifestyle medicine into practice. Teaching aids, handouts, and training materials."
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-brand-50 to-white py-16 md:py-24">
    <div class="container-page text-center max-w-3xl">
      <a href="/resources" class="inline-flex items-center gap-1.5 text-small text-brand-600 hover:text-brand-800 font-medium mb-6 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Resources
      </a>
      <span class="mb-4 inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[11px] font-bold uppercase tracking-widest bg-brand-100 text-brand-700 border border-brand-200">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
        </svg>
        For Providers & Students
      </span>
      <h1 class="font-serif text-h1 md:text-display text-brand-900">Clinical Tools & Training</h1>
      <p class="mt-6 text-body-lg text-neutral-600 max-w-2xl mx-auto">
        {d.providers?.subtitle || 'Resources for clinicians and learners looking to incorporate lifestyle medicine into practice.'}
      </p>
    </div>
  </section>

  <!-- Cards -->
  <section class="section-padding bg-white">
    <div class="container-page max-w-4xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {allItems.map((item) => {
          const isVideo = item.icon === 'video';
          const isAudio = item.icon === 'audio';
          return (
            <div class="group bg-white rounded-xl border border-neutral-200 p-6 flex flex-col hover:border-brand-200 hover:shadow-md transition-all duration-300">
              <div class="flex items-center gap-3 mb-5">
                <div class:list={[
                  "w-10 h-10 rounded-lg flex items-center justify-center shrink-0",
                  isVideo ? "bg-violet-50" : isAudio ? "bg-rose-50" : "bg-brand-50",
                ]}>
                  {isVideo ? (
                    <svg class="w-5 h-5 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.348a1.125 1.125 0 010 1.971l-11.54 6.347a1.125 1.125 0 01-1.667-.985V5.653z" />
                    </svg>
                  ) : isAudio ? (
                    <svg class="w-5 h-5 text-rose-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" />
                    </svg>
                  ) : (
                    <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
                    </svg>
                  )}
                </div>
                <span class="text-xs font-semibold text-neutral-400 tracking-wide">{item.platform}</span>
              </div>
              <div class="flex-1">
                <h3 class="text-[15px] font-semibold text-brand-900 mb-2 leading-snug">{item.title}</h3>
                <p class="text-sm text-neutral-500 leading-relaxed">{item.description}</p>
              </div>
              <a
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
                class:list={[
                  "mt-6 inline-flex items-center gap-2 text-sm font-semibold transition-colors duration-200",
                  isVideo ? "text-violet-600 hover:text-violet-700" : isAudio ? "text-rose-600 hover:text-rose-700" : "text-brand-600 hover:text-brand-700",
                ]}
              >
                {item.cta}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>
