  {
    title: "Best Blood Sugar-Friendly Foods To Buy at Costco",
    type: "article" as const,
    source: "Woman's World Magazine",
    date: "October 2025",
    href: "https://www.womansworld.com/wellness/diabetes/best-blood-sugar-friendly-foods-at-costco-safe-for-diabetics",
  },
  {
    title: "Plant Power: One of Greenville's First Lifestyle Medicine Physicians",
    type: "article" as const,
