---

<BaseLayout
  title="Media & Press"
  description="Podcasts, videos, articles, and press features with Dr. Motley on lifestyle medicine, diabetes reversal, and evidence-based health."
>
  <Hero
    badge="Media"
    headline="Media & Appearances"
    subheadline="Podcasts, videos, articles, and press features on lifestyle medicine and diabetes reversal."
    size="medium"
  >
    <div class="mt-6">
      <a href="/speaking" class="btn-primary">Book Dr. Motley for Your Podcast or Event</a>
    </div>
  </Hero>

  <!-- As Featured In — Logos -->
  <section class="py-12 bg-white border-b border-neutral-100">
    <div class="container-page">
      <p class="text-center text-small font-semibold text-neutral-400 uppercase tracking-widest mb-8">As Featured In</p>
      <div class="flex flex-wrap justify-center items-center gap-x-12 gap-y-6">
        <img src="/images/logos/dod-seal.png" alt="US Department of Defense" class="h-16 md:h-20 w-auto object-contain" loading="lazy" />
        <img src="/images/logos/aclm.png" alt="American College of Lifestyle Medicine" class="h-12 md:h-16 w-auto object-contain" loading="lazy" />
        <img src="/images/logos/aafp.png" alt="American Academy of Family Physicians" class="h-12 md:h-16 w-auto object-contain" loading="lazy" />
        <img src="/images/logos/plantstrong.png" alt="PlantStrong" class="h-12 md:h-16 w-auto object-contain" loading="lazy" />
        <img src="/images/logos/womans-world.png" alt="Woman's World Magazine" class="h-12 md:h-16 w-auto object-contain" loading="lazy" />
        <img src="/images/logos/talk-greenville.png" alt="Talk Greenville" class="h-12 md:h-16 w-auto object-contain" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Press Highlight -->
  <section class="section-padding bg-brand-50/40">
    <div class="container-page">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center max-w-5xl mx-auto">
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <img
            src="/images/press/town-magazine.jpg"
            alt="Dr. Motley featured in TOWN Magazine - Plant Power article"
            class="w-full h-auto"
            loading="lazy"
          />
        </div>
        <div>
          <span class="badge mb-4 inline-block">Press Feature</span>
          <h2 class="text-h2 font-serif text-brand-900 mb-4">Plant Power</h2>
          <p class="text-body-lg text-neutral-600 mb-4">
            "One of Greenville's first board-certified lifestyle medicine physicians promotes the healing benefits of food."
          </p>
          <p class="text-body text-neutral-500 mb-6">
            Featured in TOWN Carolina magazine, this profile explores Dr. Motley's approach to reversing chronic disease through plant-based nutrition and lifestyle interventions.
          </p>
          <a href="https://towncarolina.com/plant-power/" target="_blank" rel="noopener" class="btn-secondary inline-flex items-center gap-2">
            Read the Article
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- All Media -->
  <section class="section-padding">
    <div class="container-page">
      <SectionHeading
        title="All Media"
        subtitle="Podcasts, videos, articles, and press features"
      />
      <MediaFilter items={mediaItems} client:load />
    </div>
  </section>

  <!-- Podcast CTA -->
  <section class="bg-brand-50 section-padding">
    <div class="container-page text-center">
      <SectionHeading
        title="Invite Dr. Motley on Your Podcast"
        subtitle="Dr. Motley is available for podcast interviews, media features, and expert commentary on lifestyle medicine and diabetes reversal."
      />
      <a href="/speaking" class="btn-primary">
        Media & Speaking Inquiries
      </a>
    </div>
  </section>
</BaseLayout>
