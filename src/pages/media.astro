---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import MediaFilter from '../components/MediaFilter.tsx';
import mediaData from '../../content/pages/media.json';

const d = mediaData;
---

<BaseLayout
  title={d.seo.title}
  description={d.seo.description}
>
  <Hero
    badge={d.hero.badge}
    headline={d.hero.headline}
    subheadline={d.hero.subheadline}
    size="medium"
  >
    <div class="mt-6">
      <a href={d.hero.ctaHref} class="btn-primary">{d.hero.ctaText}</a>
    </div>
  </Hero>

  <!-- As Featured In - Logos -->
  <section class="py-12 bg-white border-b border-neutral-100">
    <div class="container-page">
      <p class="text-center text-small font-semibold text-neutral-400 uppercase tracking-widest mb-8">As Featured In</p>
      <div class="flex flex-wrap justify-center items-center gap-x-12 gap-y-6">
        {d.featuredLogos.map((logo) => (
          <img src={logo.src} alt={logo.alt} class="h-16 md:h-20 w-auto object-contain" loading="lazy" />
        ))}
      </div>
    </div>
  </section>

  <!-- Press Highlight -->
  <section class="section-padding bg-brand-50/40">
    <div class="container-page">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center max-w-5xl mx-auto">
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <img
            src={d.pressHighlight.image}
            alt={d.pressHighlight.imageAlt}
            class="w-full h-auto"
            loading="lazy"
          />
        </div>
        <div>
          <span class="badge mb-4 inline-block">{d.pressHighlight.tag}</span>
          <h2 class="text-h2 font-serif text-brand-900 mb-4">{d.pressHighlight.title}</h2>
          <p class="text-body-lg text-neutral-600 mb-4">
            "{d.pressHighlight.pullQuote}"
          </p>
          <p class="text-body text-neutral-500 mb-6">
            {d.pressHighlight.description}
          </p>
          <a href={d.pressHighlight.linkHref} target="_blank" rel="noopener" class="btn-secondary inline-flex items-center gap-2">
            {d.pressHighlight.linkText}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- All Media -->
  <section class="section-padding">
    <div class="container-page">
      <SectionHeading
        title={d.allMedia.title}
        subtitle={d.allMedia.subtitle}
      />
      <MediaFilter items={d.allMedia.items} client:load />
    </div>
  </section>

  <!-- Podcast CTA -->
  <section class="bg-brand-50 section-padding">
    <div class="container-page text-center">
      <SectionHeading
        title={d.podcastCta.title}
        subtitle={d.podcastCta.subtitle}
      />
      <a href={d.podcastCta.ctaHref} class="btn-primary">
        {d.podcastCta.ctaText}
      </a>
    </div>
  </section>
</BaseLayout>
