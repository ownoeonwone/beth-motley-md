---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import NewsletterForm from '../components/NewsletterForm';
import EventsCalendar from '../components/EventsCalendar';

const calendarId = import.meta.env.PUBLIC_GOOGLE_CALENDAR_ID || '';
const apiKey = import.meta.env.PUBLIC_GOOGLE_API_KEY || '';
---

<BaseLayout
  title="Events & Upcoming Programs | Beth Motley, MD"
  description="Upcoming diabetes reversal cohorts, speaking engagements, and lifestyle medicine events with Dr. Beth Motley in Greenville, SC."
>
  <Hero
    badge="Events & Programs"
    headline="What's Coming Up"
    subheadline="Diabetes reversal cohort start dates, speaking engagements, workshops, and community events."
    size="medium"
  />

  <!-- Events calendar -->
  <section class="section-padding">
    <div class="container-page max-w-4xl">
      <EventsCalendar
        calendarId={calendarId}
        apiKey={apiKey}
        showFeatured={true}
        showMonthHeaders={true}
        client:load
      />
    </div>
  </section>

  <!-- How to Register -->
  <section class="bg-brand-50/40 py-14 md:py-20">
    <div class="container-page max-w-5xl">
      <SectionHeading
        title="How to Register"
        subtitle="Each event has a direct link to register. Here's what to expect depending on the type."
      />
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div class="card text-center">
          <div class="w-12 h-12 rounded-full bg-brand-50 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
            </svg>
          </div>
          <h3 class="text-h4 font-serif text-brand-900 mb-2">Diabetes Reversal</h3>
          <p class="text-small text-neutral-600">
            Shared Medical Appointments through Prisma Health. Billed as standard office visits through insurance.
          </p>
        </div>
        <div class="card text-center">
          <div class="w-12 h-12 rounded-full bg-brand-50 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" />
            </svg>
          </div>
          <h3 class="text-h4 font-serif text-brand-900 mb-2">Speaking Events</h3>
          <p class="text-small text-neutral-600">
            Registration is managed by the hosting organization. Click through to the event page for details.
          </p>
        </div>
        <div class="card text-center">
          <div class="w-12 h-12 rounded-full bg-brand-50 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
            </svg>
          </div>
          <h3 class="text-h4 font-serif text-brand-900 mb-2">Workshops & CME</h3>
          <p class="text-small text-neutral-600">
            Continuing education and community events. Open registration or by invitation — details on each listing.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Can't find what you're looking for? -->
  <section class="section-padding">
    <div class="container-page">
      <div class="max-w-3xl mx-auto bg-gradient-to-br from-brand-50 to-lime-50 rounded-2xl p-8 md:p-12 text-center">
        <h2 class="text-h3 font-serif text-brand-900 mb-3">Don't See What You're Looking For?</h2>
        <p class="text-body text-neutral-600 max-w-xl mx-auto mb-6">
          New dates are added regularly. Contact Dr. Motley's office to be added to the notification list, or subscribe below.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/contact" class="btn-primary">Contact Dr. Motley</a>
          <a href="/programs/diabetes-reversal" class="btn-secondary">Learn About Programs</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="bg-brand-900 py-16 md:py-24">
    <div class="container-page text-center">
      <h2 class="text-h2 font-serif text-white mb-4">Be the First to Know</h2>
      <p class="text-body-lg text-brand-300 max-w-xl mx-auto mb-8">
        Get notified when new cohort dates open up and stay current with the latest in lifestyle medicine.
      </p>
      <div class="flex justify-center">
        <NewsletterForm client:visible dark={true} />
      </div>
    </div>
  </section>
</BaseLayout>
