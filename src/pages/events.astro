---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import NewsletterForm from '../components/NewsletterForm';
import EventsCalendar from '../components/EventsCalendar';

const calendarId = import.meta.env.PUBLIC_GOOGLE_CALENDAR_ID || '';
const apiKey = import.meta.env.PUBLIC_GOOGLE_API_KEY || '';
---

<BaseLayout
  title="Events & Upcoming Programs | Beth Motley, MD"
  description="Upcoming diabetes reversal cohorts, speaking engagements, and lifestyle medicine events with Dr. Beth Motley, MD."
>
  <Hero
    badge="Upcoming Events"
    headline="What's Coming Up"
    subheadline="Diabetes reversal cohort start dates, speaking engagements, workshops, and community events."
    size="medium"
  />

  <!-- Events list -->
  <section class="section-padding">
    <div class="container-page max-w-5xl">
      <EventsCalendar
        calendarId={calendarId}
        apiKey={apiKey}
        client:load
      />
    </div>
  </section>

  <!-- How to register note -->
  <section class="bg-brand-50/50 py-12">
    <div class="container-page max-w-3xl text-center">
      <h2 class="text-h3 font-serif text-brand-900 mb-3">How Registration Works</h2>
      <p class="text-body text-neutral-600 mb-2">
        Each event listing includes a direct link to register or sign up. For Diabetes Reversal Shared
        Medical Appointments, registration is handled through the Prisma Health patient portal.
        For speaking events, registration is managed by the hosting organization.
      </p>
      <p class="text-body text-neutral-500">
        Don't see an event that works for you?
        <a href="/contact" class="text-brand-600 hover:text-brand-800 font-medium transition-colors">
          Contact Dr. Motley
        </a>
        to be notified when new dates are added.
      </p>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="bg-brand-900 py-16 md:py-24">
    <div class="container-page text-center">
      <h2 class="text-h2 font-serif text-white mb-4">Be the First to Know</h2>
      <p class="text-body-lg text-brand-300 max-w-xl mx-auto mb-8">
        Get notified when new cohort dates open up and stay current with the latest in lifestyle medicine.
      </p>
      <div class="flex justify-center">
        <NewsletterForm client:visible dark={true} />
      </div>
    </div>
  </section>
</BaseLayout>
