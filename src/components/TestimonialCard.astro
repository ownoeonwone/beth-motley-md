---
interface Props {
  quote: string;
  name: string;
  role?: string;
}

const { quote, name, role } = Astro.props;
---

<blockquote class="card border-l-4 border-l-brand-500">
  <svg class="w-8 h-8 text-brand-200 mb-3" fill="currentColor" viewBox="0 0 24 24">
    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151C7.563 6.068 6 8.789 6 11h4v10H0z" />
  </svg>
  <p class="text-body-lg text-neutral-700 italic leading-relaxed">{quote}</p>
  <footer class="mt-4">
    <cite class="not-italic">
      <span class="text-small font-semibold text-brand-900">{name}</span>
      {role && <span class="text-small text-neutral-500 block">{role}</span>}
    </cite>
  </footer>
</blockquote>
