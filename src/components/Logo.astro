---
interface Props {
  variant?: 'horizontal' | 'icon';
  dark?: boolean;
  class?: string;
}

const { variant = 'horizontal', dark = false, class: className } = Astro.props;
---

{variant === 'icon' ? (
  <img
    src="/images/logo/icon-blue.png"
    alt="Beth Motley MD logo"
    class:list={["h-10 w-10", className]}
  />
) : (
  <img
    src={dark ? "/images/logo/beth-motley-md-white-tagline.svg" : "/images/logo/beth-motley-md-colour-tagline.svg"}
    alt="Beth Motley, MD — Lifestyle Medicine"
    class:list={["h-12", className]}
  />
)}
