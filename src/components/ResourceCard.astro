---
interface Props {
  title: string;
  type: string;
  href: string;
  bethPick?: boolean;
  description: string;
}

const { title, type, href, bethPick = false, description } = Astro.props;

const typeStyles: Record<string, string> = {
  'Starter guide': 'bg-emerald-50 text-emerald-700 border-emerald-200',
  'Tool / app':    'bg-violet-50 text-violet-700 border-violet-200',
  'Key evidence':  'bg-blue-50 text-blue-700 border-blue-200',
};

const typeStyle = typeStyles[type] || 'bg-neutral-50 text-neutral-600 border-neutral-200';
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class="group flex items-start gap-4 py-4 border-b border-neutral-100 last:border-0 px-3 -mx-3 rounded-lg hover:bg-neutral-50 transition-colors duration-200"
>
  <!-- Type badge -->
  <span class:list={["shrink-0 mt-0.5 inline-flex items-center px-2 py-0.5 rounded text-[11px] font-semibold tracking-wide border whitespace-nowrap", typeStyle]}>
    {type}
  </span>

  <!-- Content -->
  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-2 flex-wrap">
      <span class="text-[15px] font-semibold text-brand-900 group-hover:text-brand-700 transition-colors leading-snug">
        {title}
      </span>
      {bethPick && (
        <span class="inline-flex items-center gap-1 text-[11px] font-bold text-amber-600 tracking-wide">
          <svg class="w-3 h-3 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
          Beth's pick
        </span>
      )}
      <svg class="w-3.5 h-3.5 text-neutral-300 group-hover:text-brand-400 transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
    </div>
    <p class="text-sm text-neutral-500 mt-1 leading-relaxed">{description}</p>
  </div>
</a>
