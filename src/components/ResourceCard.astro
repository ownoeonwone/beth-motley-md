---
interface Props {
  title: string;
  type: string;
  href: string;
  badges: string[];
  bethPick?: boolean;
  description: string;
}

const { title, type, href, badges, bethPick = false, description } = Astro.props;

/* Type badge color map — consistent across all pillar sections */
const typeColors: Record<string, string> = {
  'Starter guide': 'bg-emerald-100 text-emerald-800 border-emerald-200',
  'Tool / app':    'bg-violet-100 text-violet-800 border-violet-200',
  'Key study':     'bg-blue-100 text-blue-800 border-blue-200',
  'Book or film':  'bg-amber-100 text-amber-800 border-amber-200',
};

const typeColor = typeColors[type] || 'bg-neutral-100 text-neutral-700 border-neutral-200';
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class:list={[
    "group block rounded-[10px] border p-5 md:p-6 transition-all duration-300",
    bethPick
      ? "bg-brand-50/60 border-brand-200 hover:shadow-md hover:border-brand-300"
      : "bg-white border-neutral-100 hover:shadow-md hover:border-neutral-200",
  ]}
>
  <!-- Top row: type pill + badge pills -->
  <div class="flex flex-wrap items-center gap-2 mb-3">
    <span class:list={["inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold border", typeColor]}>
      {type}
    </span>
    {badges.map((badge) => (
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-neutral-50 text-neutral-500 border border-neutral-100">
        {badge}
      </span>
    ))}
    {bethPick && (
      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-lime-100 text-lime-800 border border-lime-200">
        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
        Beth's Pick
      </span>
    )}
  </div>

  <!-- Title with external link icon -->
  <h3 class="text-h4 font-serif text-brand-900 mb-2 group-hover:text-brand-700 transition-colors flex items-start gap-2">
    <span>{title}</span>
    <svg class="w-4 h-4 mt-1 flex-shrink-0 text-neutral-400 group-hover:text-brand-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
    </svg>
  </h3>

  <!-- Description -->
  <p class="text-small text-neutral-600 leading-relaxed">{description}</p>
</a>
