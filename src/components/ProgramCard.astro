---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: 'heart' | 'star';
  features?: string[];
}

const { title, description, href, icon, features = [] } = Astro.props;
---

<a href={href} class="card group block hover:border-brand-200 transition-all duration-300">
  <div class="w-12 h-12 rounded-full bg-brand-50 flex items-center justify-center mb-5 group-hover:bg-brand-100 transition-colors">
    {icon === 'heart' ? (
      <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
      </svg>
    ) : (
      <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
      </svg>
    )}
  </div>
  <h3 class="text-h3 font-serif text-brand-900 mb-3">{title}</h3>
  <p class="text-body text-neutral-600 mb-5">{description}</p>
  {features.length > 0 && (
    <ul class="space-y-2 mb-5">
      {features.map((f) => (
        <li class="flex items-start gap-2 text-small text-neutral-600">
          <svg class="w-4 h-4 text-lime-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          {f}
        </li>
      ))}
    </ul>
  )}
  <span class="inline-flex items-center text-small font-medium text-brand-600 group-hover:text-brand-800 transition-colors">
    Learn more
    <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </span>
</a>
