---
const credentials = [
  'MD: EVMS / Old Dominion University',
  'FACLM: Fellow, American College of Lifestyle Medicine',
  'Board-Certified Family Medicine',
  'BS Biomedical Engineering: University of Virginia',
];
---

<section class="bg-brand-900 py-6 overflow-hidden">
  <div class="container-page">
    <div class="flex flex-wrap justify-start gap-x-8 gap-y-3">
      {credentials.map((cred) => (
        <div class="flex items-center gap-2 text-small text-brand-200">
          <svg class="w-4 h-4 text-lime-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
          <span>{cred}</span>
        </div>
      ))}
    </div>
  </div>
</section>
