# Form submission endpoint (Formspree, GoHighLevel webhook, or any URL that accepts POST)
PUBLIC_FORM_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID

# Newsletter signup endpoint (ConvertKit/Kit form, Mailchimp, etc.)
PUBLIC_NEWSLETTER_ENDPOINT=https://app.convertkit.com/forms/YOUR_FORM_ID/subscriptions

# Site URL (used for SEO / sitemap)
PUBLIC_SITE_URL=https://www.bethmotleymd.com

# Google Calendar (for the /events page)
# PUBLIC_ prefix makes these available client-side (safe — calendar is public)
# Calendar ID: Google Calendar settings → "Integrate calendar" → Calendar ID
# API Key: console.cloud.google.com → APIs & Services → Credentials → Create API key
#          Restrict key to "Google Calendar API" and your site domain
PUBLIC_GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com
PUBLIC_GOOGLE_API_KEY=your_google_api_key_here

# Sanity CMS (get these from https://sanity.io/manage after creating your project)
# Project ID is shown on the project dashboard
SANITY_PROJECT_ID=
SANITY_DATASET=production

# Studio env vars (used inside the studio/ directory)
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production

# Write token — only needed for the seed script (scripts/seed-sanity.mjs)
# Create at sanity.io/manage → API → Tokens → Add API token (Editor role)
SANITY_TOKEN=
